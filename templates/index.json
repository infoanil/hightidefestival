        },
        "faq_item_NDWEUb": {
          "type": "faq_item",
          "settings": {
            "question": "Is there re-entry?",
            "answer": "No re-entry due to venue policy."
          }
        },
        "faq_item_YxaPEC": {
          "type": "faq_item",
          "settings": {
            "question": "What forms of payment are accepted?",
            "answer": "This is a cashless event. Bring debit/credit cards"
          }
        },
