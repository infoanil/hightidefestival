          "settings": {
            "question": "WHERE IS HIGH TIDE?",
            "answer": "High Tide Festival is taking place at Riverfront Park in N. Charleston 1061 Everglades Ave, North Charleston, SC 29405"
          }
        },
        "faq_item_PywFU6": {
          "type": "faq_item",
          "settings": {
            "question": "What is the age limit?",
            "answer": "21+ only. We scan IDs."
          }
        },
        "faq_item_9QVyR4": {
          "type": "faq_item",
          "settings": {
            "question": "What is the refund policy?",
            "answer": "Tickets are non-refundable. No exceptions."
          }
        },
        "faq_item_6JVGNK": {
          "type": "faq_item",
          "settings": {
            "question": "When should I arrive?",
            "answer": "Gates open at 12PM. Come early!"
