{% comment %}
  Universal Image Helper
  Supports:
  - width: (integer)
  - max_width: (integer)
  - widths: '200,400,800,...'
  - sizes: HTML sizes attribute
  - class: custom classes
{% endcomment %}

{% if mode == 'data' %}
  {  
    "src": "{{ img | image_url: width: base_width }}",  
    "srcset": "{% for w in widths_array %}
    {{ img | image_url: width: w }} {{ w }}w{% unless forloop.last %},
    {% endunless %}
  {% endfor %}",  
    "sizes": "{{ sizes | default: '(min-width: 1024px) 100vw, 100vw' }}",  
    "alt": "{{ img.alt | escape }}"  
  }
{% else %}

  {% assign img = image | default: placeholder %}

    {% if img %}

    {%- comment -%}
      Determine which widths to generate
    {%- endcomment -%}

    {% if widths %}
      {% assign widths_array = widths | split: ',' %}
    {% elsif max_width %}
      {% assign widths_array = '200,400,600,800,1200,1600,2000,2400,3000' | split: ',' %}
    {% else %}

      {% assign widths_array = '200,400,600,800,1200' | split: ',' %}
    {% endif %}

    {%- comment -%}
      Build srcset dynamically from widths_list
    {%- endcomment -%}
    {% capture srcset %}
    {% for w in widths_array %}
      {{ img | image_url: width: w | escape }} {{ w }}w{% unless forloop.last %}, {% endunless %}
    {% endfor %}
  {% endcapture %}
    {%- comment -%}
      Determine base src width:
      - priority 1: width= override
      - priority 2: max_width
      - fallback: 600
    {%- endcomment -%}
    {% if width %}
      {% assign base_width = width %}
    {% elsif max_width %}
      {% assign base_width = max_width %}
    {% else %}
      {% assign base_width = 600 %}
    {% endif %}

    <img
      src="{{ img | image_url: width: base_width }}"
      srcset="{{ srcset }}"
      sizes="{{ sizes | default: '(min-width: 1024px) 100vw, 100vw' }}"
      alt="{{ img.alt | escape }}"
      class=" {{ class }}"
      loading="lazy">

  {% else %}
    <div class="w-full h-full bg-gray-200 flex items-center justify-center">
      <span class="text-gray-500 text-sm">No image</span>
    </div>
  {% endif %}
{% endif %}