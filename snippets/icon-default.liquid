{%- assign class = class | default: "h-12 w-12 text-[var(--interactive-default)]" -%}

  <svg
  class="{{ class }}"
  xmlns="http://www.w3.org/2000/svg"
  fill="none"
  viewBox="0 0 24 24"
  stroke="currentColor"
  stroke-width="2"
  aria-hidden="true">
    <!-- Simple circular info icon -->
  <circle
    cx="12"
    cy="12"
    r="9"
    stroke="currentColor"
    stroke-width="2" />
  <line
    x1="12"
    y1="8"
    x2="12"
    y2="12"
    stroke="currentColor"
    stroke-linecap="round" />
  <circle
    cx="12"
    cy="16"
    r="1"
    fill="currentColor" />
</svg>