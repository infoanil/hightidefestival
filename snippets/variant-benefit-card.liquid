{% comment %}
  Variant Benefit Card Snippet - Same to Same Design
  Displays detailed benefits for a specific variant value.
{% endcomment %}

{% liquid
  assign description = "Full GA & VIP + Stage Access Benefits: 50+ djs, food & cocktail gardens, art installations, brand partner activations, no-line festival entry, a/c restrooms, and premium vip bar"
  case value
    when 'General Admission'
      assign description = "Admission to High Tide Festival, 50+ artists, food & cocktail gardens, art installations, and brand partner activations."
    when 'VIP'
      assign description = "All GA benefits plus: dedicated VIP entry, premium viewing areas, private VIP bars, and air-conditioned restrooms."
    when 'Stage Access'
      assign description = "Full GA + VIP benefits: 50+ djs, food & cocktail gardens, art installations, brand partner activations, no-line festival entry, a/c restrooms, and premium vip bars."
  endcase
%}

