{% comment %}
  Password protection wall for passes page
  This snippet shows a password form that blocks access to protected content
  until the correct password is entered.
  Styled to match the hero section.
{% endcomment %}

<div 
  x-data="passesPasswordWall()" 
  x-show="!unlocked" 
  x-cloak
  class="relative min-h-[800px] overflow-hidden flex flex-col"
>
  {% comment %} Background Image {% endcomment %}
  <div class="absolute inset-0 z-[-0]">
    {% if settings.passes_password_background %}
      {% render 'image-helper'
        , image: settings.passes_password_background
        , max_width: 2000
        , sizes: '(min-width: 1024px) 50vw, 100vw'
        , class: 'w-full h-full object-cover object-bottom'
      %}
      {% comment %} Dark overlay {% endcomment %}
      <div class="absolute inset-0 bg-black/40"></div>
    {% else %}
      <div class="w-full h-full bg-secondary-navy"></div>
    {% endif %}

    {% comment %} Ornament SVG {% endcomment %}
    <span class="absolute top-0 left-1/2 -translate-x-1/2 pointer-events-auto">
      <svg id="password-svg" width="1440" height="515" viewBox="0 0 1440 515" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="0.795898" width="1859.16" height="1859.16" transform="matrix(0.795898 -0.605431 0.795898 0.605431 -760.838 -611.316)" stroke="white" stroke-opacity="0.3"/>
        <rect x="0.795898" width="1859.16" height="1859.16" transform="matrix(0.795898 -0.605431 0.795898 0.605431 -760.838 -668.316)" stroke="white" stroke-opacity="0.3"/>
        <rect x="0.795898" width="1859.16" height="1859.16" transform="matrix(0.795898 -0.605431 0.795898 0.605431 -760.838 -735.316)" stroke="white" stroke-opacity="0.3"/>
        <rect x="0.795898" width="1859.16" height="1859.16" transform="matrix(0.795898 -0.605431 0.795898 0.605431 -760.838 -794.316)" stroke="white" stroke-opacity="0.3"/>
        <rect x="0.795898" width="1859.16" height="1859.16" transform="matrix(0.795898 -0.605431 0.795898 0.605431 -760.838 -851.316)" stroke="white" stroke-opacity="0.3"/>
        <rect x="0.795898" width="1859.16" height="1859.16" transform="matrix(0.795898 -0.605431 0.795898 0.605431 -760.838 -918.316)" stroke="white" stroke-opacity="0.3"/>
      </svg>
    </span>

    <style>
      #password-svg rect:nth-child(6) {
        animation: fade-out-pwd 3s linear infinite;  
        animation-delay: 0s;
      }
      #password-svg rect:nth-child(5) {
        animation: fade-out-pwd 3s linear infinite;  
        animation-delay: 0s;
      }
      #password-svg rect:nth-child(4) {
        animation: fade-out-pwd 3s linear infinite;
        animation-delay: 0.5s;
      }
      #password-svg rect:nth-child(3) {
        animation: fade-out-pwd 3s linear infinite;  
        animation-delay: 1s;
      }
      #password-svg rect:nth-child(2) {
        animation: fade-out-pwd 3s linear infinite;  
        animation-delay: 1.5s;
      }
      #password-svg rect:nth-child(1) {
        animation: fade-out-pwd 3s linear infinite;  
        animation-delay: 2s;
      }

      @keyframes fade-out-pwd {
        0% { opacity: 1; }
        50% { opacity: 0; }
      }
    </style>
  </div>

  {% comment %} Content {% endcomment %}
  <div class="container flex flex-col h-full z-1 relative flex-1">
    <div class="flex-1 flex flex-col justify-center">
      {% comment %} Logo {% endcomment %}
      <div class="content__media pt-6">
        <span class="w-full">
          {% if settings.passes_password_logo %}
            {% render 'image-helper'
              , image: settings.passes_password_logo
              , max_width: 688
              , sizes: '(min-width: 1024px) 50vw, 100vw'
              , class: 'mx-auto h-auto w-full md:w-[488px] object-contain'
            %}
          {% endif %}
        </span>    
      </div>

      {% comment %} CTA / Form {% endcomment %}
      <div class="cta flex flex-col items-center text-white md:max-w-[660px] mx-auto w-full">
        <p class="max-sm:text-balance text-[35px] leading-[36px] md:text-[50px] md:leading-[54px] tracking-[-1px] uppercase font-amaya mb-5 md:mb-7.5 text-center">
          Pre Sale Access
        </p>

        <p class="text-[17px] leading-[20px] tracking-[-1px] font-semibold mb-2 text-center">
          Use your pre sale code here to enter our sale.
        </p>
        <p class="text-[17px] leading-[20px] tracking-[-1px] font-semibold mb-2 text-center">
          If you have already signed up for the pre sale you should have received a code via email or text.
        </p>
        <p class="text-[17px] leading-[20px] tracking-[-1px] font-semibold mb-2 text-center">
          If you have not signed up for pre sale access you can sign up at the top of our homepage.
        </p>

        {% comment %} Password Form {% endcomment %}
        <form @submit.prevent="checkPassword()" class="w-full max-w-[440px] flex flex-col items-center gap-4 mt-6">
          <input 
            type="text" 
            x-model="password"
            x-ref="passwordInput"
            placeholder="Insert code"
            class="w-full rounded-[10px] border border-white/70 px-4 py-3 bg-white text-secondary-navy font-semibold placeholder:text-secondary-navy/60"
            :class="{ 'border-red-500': error }"
          >
          
          <button 
            type="submit"
            class="w-full rounded-[10px] bg-trietary-orange hover:bg-secondary-navy transition duration-200 text-white uppercase font-extrabold text-lg py-3 px-6"
          >
            {{ settings.passes_password_button_text | default: 'Submit' }}
          </button>
          
          <p 
            x-show="error" 
            class="font-extrabold text-white text-center"
          >
            {{ settings.passes_password_error_message | default: 'Invalid code. Please try again.' }}
          </p>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  function passesPasswordWall() {
    return {
      password: '',
      error: false,
      unlocked: false,
      
      init() {
        // Check if already unlocked in this session
        const sessionUnlocked = sessionStorage.getItem('passes_unlocked');
        if (sessionUnlocked === 'true') {
          this.unlocked = true;
        }
      },
      
      checkPassword() {
        const correctPassword = '{{ settings.passes_password }}';
        
        if (this.password === correctPassword) {
          this.error = false;
          this.unlocked = true;
          // Store in session so user doesn't have to re-enter during this session
          sessionStorage.setItem('passes_unlocked', 'true');
          // Dispatch event to show content
          window.dispatchEvent(new CustomEvent('passes-unlocked'));
        } else {
          this.error = true;
          this.password = '';
          this.$refs.passwordInput.focus();
        }
      }
    }
  }
</script>
</script>
