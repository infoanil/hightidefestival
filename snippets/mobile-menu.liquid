{% comment %}
  Mobile menu drawer.
  Expected:
  - menu (link_list): navigation menu
  - mobile_menu_state (string): Alpine state variable name controlling visibility
{% endcomment %}

{% assign menu = menu | default: settings.header_menu %}

  <div
  x-show="{{ mobile_menu_state }}"
  x-cloak
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="opacity-0"
  x-transition:enter-end="opacity-100"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="opacity-100"
  x-transition:leave-end="opacity-0"
  class="relative z-50 lg:hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="mobile-menu-title">
  {%- comment -%} Backdrop {%- endcomment -%}
  <div class="fixed inset-0 bg-black/40 backdrop-blur-sm" @click="{{ mobile_menu_state }} = false"></div>

  {%- comment -%} Drawer panel {%- endcomment -%}
  <div class="fixed inset-y-0 right-0 z-50 w-full sm:max-w-sm">
    <div
      x-transition:enter="transition ease-in-out duration-300 transform"
      x-transition:enter-start="translate-x-full"
      x-transition:enter-end="translate-x-0"
      x-transition:leave="transition ease-in-out duration-300 transform"
      x-transition:leave-start="translate-x-0"
      x-transition:leave-end="translate-x-full"
      class="h-full overflow-y-auto bg-bg-color p-6 sm:ring-1 sm:ring-[var(--interactive-border)] focus:outline-none"
      tabindex="-1">
      <div class="flex items-center justify-between border-b border-secondary-navy pb-4">
        {% render 'header-logo'
          , logo_image: settings.dark_logo
          , compact: true %}

        <button
          type="button"
          @click="{{ mobile_menu_state }} = false"
          class="-m-2.5 rounded-md p-2.5 text-[var(--text-primary)] hover:text-[var(--link-hover)]">
          <span class="sr-only">Close menu</span>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 5L12 12M12 12L19 5M12 12L5 19M12 12L19 19" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>

        </button>
      </div>

      <div class="mt-6 flow-root">
        <h2 id="mobile-menu-title" class="sr-only">Mobile navigation</h2>

        {% comment %} <form
          action="/search"
          method="get"
          class="flex items-center border border-[var(--interactive-border)]
                 rounded-full px-3 py-2 mb-4 bg-[var(--surface-secondary)]">
          <svg
            class="w-5 h-5 text-[var(--text-secondary)]"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            id="mobile-search-input"
            name="q"
            class="w-full border-none focus:outline-none ml-2 bg-transparent text-[var(--text-primary)]"
            type="search"
            placeholder="Search products..."
            autocomplete="off">
        </form>

        <div id="mobile-search-results" class="space-y-3 hidden max-h-[60vh] overflow-y-auto pr-1 mt-2 border-t border-[var(--interactive-border)]"></div> {% endcomment %}

        <div class="mt-4 ">
          {% render 'menu-sidebar'
            , menu: menu %}

          <hr class="w-full border-secondary-navy my-7.5">

          <div class="flex-1 justify-end  lg:flex text-secondary-navy mb-7.5">
            {% render 'header-actions'
           , section: section layout: layout %}
          </div>
          <a href="{{ settings.header_button_url }}" {% if settings.header_open_in_a_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %} class="block text-[15px] bg-trietary-orange rounded-[5px] text-center py-4 uppercase font-extrabold tracking-[-1px] text-white">{{settings.header_button_title}}</a>
          <p class="mt-7.5 font-amaya text-[23px] uppercase leading-[31px] text-secondary-navy">{{settings.header_text_after_logo}}</p>

       <div class="flex-1 justify-end hidden lg:flex">
         
       </div>
        </div>
      </div>
    </div>
  </div>
</div>