<section class="pr-reviews-section">
  {% assign reviews = product.metafields.custom.artist_ab_test_details.value.pdp_reviews.value %}

  <div class="pr-carousel-wrapper">
    <button class="pr-nav-btn pr-nav-prev" id="pr-prev-btn" aria-label="Previous review">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M7.99967 12.6673L3.33301 8.00065L7.99967 3.33398" stroke="#1B1B1B" stroke-width="1.33333" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M12.6663 8H3.33301" stroke="#1B1B1B" stroke-width="1.33333" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="pr-card" id="pr-card">
      {% if reviews %}
        {% for review in reviews %}
          {%- assign full_stars = review.rating | plus: 0 -%}
          {%- assign empty_stars = 5 | minus: full_stars -%}

          <div class="pr-slide {% if forloop.first %}pr-slide--active{% endif %}" data-index="{{ forloop.index0 }}">
            <div class="pr-card-header">
              <span class="pr-author">{{ review.name }}</span>
              <div class="pr-stars" aria-label="Rating: {{ full_stars }} out of 5">
                {% for i in (1..full_stars) %}
                  <svg width="17" height="16" viewBox="0 0 17 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M16.1959 5.9786C16.1959 5.74663 16.0167 5.59901 15.6582 5.53575L10.7551 4.8082L8.57245 0.379624C8.44592 0.126563 8.28776 3.24249e-05 8.09796 3.24249e-05C7.90816 3.24249e-05 7.75 0.126563 7.62347 0.379624L5.44082 4.8082L0.537755 5.53575C0.179252 5.59901 0 5.74663 0 5.9786C0 6.12622 0.0843537 6.28439 0.253061 6.45309L3.79592 9.90105L2.94184 14.7725C2.94184 14.8568 2.94184 14.9201 2.94184 14.9623C2.94184 15.0888 2.97347 15.1995 3.03673 15.2944C3.1 15.3893 3.20544 15.4368 3.35306 15.4368C3.4585 15.4368 3.58503 15.3946 3.73265 15.3102L8.09796 13.0327L12.4633 15.3102C12.6109 15.3946 12.7374 15.4368 12.8429 15.4368C12.9905 15.4368 13.0959 15.3893 13.1592 15.2944C13.2224 15.1995 13.2541 15.0888 13.2541 14.9623C13.2541 14.8779 13.2541 14.8147 13.2541 14.7725L12.4 9.90105L15.9429 6.45309C16.1116 6.28439 16.1959 6.12622 16.1959 5.9786Z" fill="#E6772A"/>
                  </svg>
                {% endfor %}
                {% if empty_stars > 0 %}
                  {% for i in (1..empty_stars) %}
                    <svg width="17" height="16" viewBox="0 0 17 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M16.1959 5.9786C16.1959 5.74663 16.0167 5.59901 15.6582 5.53575L10.7551 4.8082L8.57245 0.379624C8.44592 0.126563 8.28776 3.24249e-05 8.09796 3.24249e-05C7.90816 3.24249e-05 7.75 0.126563 7.62347 0.379624L5.44082 4.8082L0.537755 5.53575C0.179252 5.59901 0 5.74663 0 5.9786C0 6.12622 0.0843537 6.28439 0.253061 6.45309L3.79592 9.90105L2.94184 14.7725C2.94184 14.8568 2.94184 14.9201 2.94184 14.9623C2.94184 15.0888 2.97347 15.1995 3.03673 15.2944C3.1 15.3893 3.20544 15.4368 3.35306 15.4368C3.4585 15.4368 3.58503 15.3946 3.73265 15.3102L8.09796 13.0327L12.4633 15.3102C12.6109 15.3946 12.7374 15.4368 12.8429 15.4368C12.9905 15.4368 13.0959 15.3893 13.1592 15.2944C13.2224 15.1995 13.2541 15.0888 13.2541 14.9623C13.2541 14.8779 13.2541 14.8147 13.2541 14.7725L12.4 9.90105L15.9429 6.45309C16.1116 6.28439 16.1959 6.12622 16.1959 5.9786Z" fill="#ddd"/>
                    </svg>
                  {% endfor %}
                {% endif %}
              </div>
            </div>
            <p class="pr-content text-secondary-navy/80">
              {{ review.review_description | metafield_tag }}
            </p>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    <button class="pr-nav-btn pr-nav-next" id="pr-next-btn" aria-label="Next review">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M8.00049 12.6673L12.6672 8.00065L8.00049 3.33398" stroke="#1B1B1B" stroke-width="1.33333" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M3.3335 8H12.6668" stroke="#1B1B1B" stroke-width="1.33333" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</section>

<style>
  .pr-reviews-section {
    padding: 43px 0 25px 0;
  }
  .pr-carousel-wrapper {
    gap: 16px;
    max-width: 680px;
    margin: 0 auto;
    position: relative;
  }
  .pr-card {
    flex: 1;
    background: #ffffff;
    border: 2px solid #1a3a5c;
    margin: 0 16px;
    border-radius: 5px;
    padding: 24px 34px;
    min-height: 175px;
    position: relative;
    overflow: hidden;
  }
  .pr-slide {
    display: none;
    animation: prFadeIn 0.35s ease;
  }
  .pr-slide--active {
    display: block;
  }
  @keyframes prFadeIn {
    from {
      opacity: 0;
      transform: translateX(12px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  .pr-card-header {
    height: 38px;
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .pr-author {
    font-size: 16px;
    font-weight: 800;
    line-height: 37.5px;
    letter-spacing: -1px;
    color: #1a3a5c;
  }
  .pr-stars {
    display: flex;
    gap: 2px;
  }
  .pr-star {
    font-size: 1.25rem;
    line-height: 1;
  }
  .pr-star--filled {
    color: #e07b2a;
  }
  .pr-star--empty {
    color: #ddd;
  }
  .pr-content,
  .artist-ab-test .metafield-rich_text_field{
    font-weight: 600;
    font-size: 17px;
    line-height: 20px;
    letter-spacing: -1px;
    margin: 0 0 10px 0;
      color: #0B4166;
  }
  .pr-nav-btn {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    z-index: 1;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    border: 2px solid #1a3a5c;
    border-radius: 5px;
    background: #ffffff;
    color: #1a3a5c;
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, color 0.2s ease, transform 0.15s ease;
    user-select: none;
  }
  .pr-nav-prev {
    left: 0;
  }
  .pr-nav-next {
    right: 0;
  }
  .pr-nav-btn:hover {
    transform: translateY(-50%) scale(1.06);
  }
  .pr-nav-btn:active {
    transform: translateY(-50%) scale(0.97);
  }
  .pr-nav-btn:disabled {
    opacity: 0.35;
    cursor: default;
    pointer-events: none;
  }
  .pr-empty {
    text-align: center;
    color: #7a8fa6;
    font-size: 0.95rem;
    padding: 32px 0;
  }
  @media (max-width: 500px) {
    .pr-card {
      padding: 21px 24px;
    }
    .pr-nav-btn {
      width: 32px;
      height: 32px;
    }
    .pr-reviews-section {
      padding: 29px 0 25px 0;
        background: #D1E1EF;
        border: 1px solid #0B4166;
        border-left: 0;
        border-right: 0;
        margin-left: -16px;
        margin-right: -16px;
        margin-top: 21px;
    }
      .pr-card{
          margin: 0 26px;
      }
      .pr-nav-next{
          right: 10px;
      }
      .pr-nav-prev{
          left: 10px;
      }
      .pr-card-header {
          flex-direction: row-reverse;
          justify-content: flex-end;
      }
  }
</style>

<script>
  (function () {
    var slides = document.querySelectorAll('.pr-slide');
    var card = document.getElementById('pr-card');
    var prevBtn = document.getElementById('pr-prev-btn');
    var nextBtn = document.getElementById('pr-next-btn');
    var current = 0;

    var isDragging = false;
    var startX = 0;
    var deltaX = 0;
    var dragThreshold = 50;

    var autoplayInterval = null;

    function startAutoplay() {
      autoplayInterval = setInterval(function () {
        goTo(current + 1);
      }, 6000);
    }

    function stopAutoplay() {
      if (autoplayInterval) {
        clearInterval(autoplayInterval);
        autoplayInterval = null;
      }
    }

    function restartAutoplay() {
      stopAutoplay();
      startAutoplay();
    }

    if (!slides.length) return;

    function goTo(index) {
      slides[current].classList.remove('pr-slide--active');
      current = (index + slides.length) % slides.length;
      slides[current].classList.add('pr-slide--active');
    }

    if (prevBtn)
      prevBtn.addEventListener('click', function () {
        goTo(current - 1);
        restartAutoplay();
      });
    if (nextBtn)
      nextBtn.addEventListener('click', function () {
        goTo(current + 1);
        restartAutoplay();
      });

    function dragStart(e) {
      isDragging = true;
      startX = e.touches ? e.touches[0].clientX : e.clientX;
      deltaX = 0;
      stopAutoplay();
      if (card) card.style.cursor = 'grabbing';
    }

    function dragMove(e) {
      if (!isDragging) return;
      var x = e.touches ? e.touches[0].clientX : e.clientX;
      deltaX = x - startX;
    }

    function dragEnd() {
      if (!isDragging) return;
      if (deltaX > dragThreshold) {
        goTo(current - 1);
      } else if (deltaX < -dragThreshold) {
        goTo(current + 1);
      }
      isDragging = false;
      deltaX = 0;
      if (card) card.style.cursor = 'grab';
      restartAutoplay();
    }

    if (card) {
      card.addEventListener('mousedown', function (e) {
        e.preventDefault();
        dragStart(e);
      });
      card.addEventListener('mousemove', function (e) {
        e.preventDefault();
        dragMove(e);
      });
      card.addEventListener('mouseup', dragEnd);
      card.addEventListener('mouseleave', dragEnd);

      card.addEventListener('touchstart', dragStart, { passive: true });
      card.addEventListener('touchmove', dragMove, { passive: true });
      card.addEventListener('touchend', dragEnd);

      card.style.cursor = 'grab';
    }

    startAutoplay();
  })();
</script>
