{%- comment -%}
  Mobile sidebar menu (accordion style)

  Params:
  - menu: link_list OR link object (must have `.links`)
  - level: nesting level (1 = top)
{%- endcomment -%}

{% assign menu = menu | default: false %}
{% assign level = level | default: 1 %}

{% if menu == false %}
  <p class="text-red-600 text-sm">Invalid menu object</p>
{% else %}

  {%- comment -%}
    Indentation / padding by level (Tailwind classes must be explicit)
  {%- endcomment -%}
  {% case level %}
    {% when 1 %}
      {% assign item_padding = "px" %}
    {% when 2 %}
      {% assign item_padding = "pl-4 pr-3" %}
    {% else %}
      {% assign item_padding = "pl-7 pr-3" %}
  {% endcase %}

  <ul class="space-y-4.5">
    {% for link in menu.links %}
      {%- assign children_count = link.links.size -%}
      {%- assign has_children = children_count -%}

      <li>
        {% if has_children == 0 %}
          {% comment %} SIMPLE LINK {% endcomment %}
          <a href="{{ link.url }}" class="block {{ item_padding }} text-[30px] leading-[100%]  text-secondary-navy uppercase font-extrabold uppercase
                   hover:bg-[var(--surface-secondary)] rounded-md">
            {{ link.title | escape }}
          </a>

        {% else %}
          {% comment %} PARENT WITH CHILDREN (ACORDION) {% endcomment %}
          {% assign next_level = level | plus: 1 %}

          <details class="group">
            <summary class="flex items-center justify-between {{ item_padding }} py-2
                     cursor-pointer text-[var(--text-primary)]
                     hover:bg-[var(--surface-secondary)] rounded-md">
              <span>{{ link.title | escape }}</span>

              <svg
                class="size-4 text-[var(--text-secondary)] transition-transform group-open:rotate-180"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true">
                <path
                  fill-rule="evenodd"
                  d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z"
                  clip-rule="evenodd" />
              </svg>
            </summary>

            <div class="mt-1 border-l border-[var(--interactive-border)]">
              {% render 'menu-sidebar'
                , menu: link
                , level: next_level %}
            </div>
          </details>

        {% endif %}
      </li>
    {% endfor %}
  </ul>

{% endif %}