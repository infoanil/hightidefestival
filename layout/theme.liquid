  {% render 'elevateab' %}
    {% # Inlined CSS Variables %}
  {% render 'css-variables' %}

    {% # Load and preload the critical CSS %}
    {% comment %} {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }} {% endcomment %}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {%- liquid
      render 'vite-tag' with 'main.css'
      render 'vite-tag' with 'main.js'
    -%}
    <script>
      window.CandyRackSliderCart = window.CandyRackSliderCart || {};
    </script>
    {% if template.name == 'collection' and template.suffix == 'passes' %}
      {{ 'magicpass.css' | asset_url | stylesheet_tag }}
    {% endif %}
    {{ content_for_header }}

</head>

  <body class="bg-bg-color">
    <!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-P8GPJQ84"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->
    {% sections 'header-group' %}

    {% comment %} Password protection for passes page {% endcomment %}
    {% if settings.passes_password_enabled and template.suffix == 'passes' %}
      {% render 'passes-password-wall' %}
      <div x-data="{ unlocked: sessionStorage.getItem('passes_unlocked') === 'true' }" x-show="unlocked" x-cloak @passes-unlocked.window="unlocked = true">
        {{ content_for_layout }}
      </div>
    {% else %}
      {{ content_for_layout }}
    {% endif %}

    {% sections 'footer-group' %}

    <script>
      window.addEventListener('cart:add', () => {
        console.log('[High Tide Debug] cart:add event fired');
      });

      window.addEventListener('passes-unlocked', () => {
        console.log('[High Tide Debug] passes-unlocked event fired');
      });
    </script>
    {% if template contains 'account' %}
  {% if customer.metafields.custom.ticket_id != blank %}
    <div class="custom-ticket-wrap" style="max-width: 450px; margin: 40px auto; padding: 30px; border: 4px solid #000; border-radius: 15px; background-color: #fff; text-align: center; box-shadow: 0 15px 35px rgba(0,0,0,0.15); position: relative; z-index: 100;">
      <h2 style="margin: 0 0 10px 0; font-size: 1.8em; color: #000; letter-spacing: 1px;">🎟️ YOUR ENTRY PASS</h2>
      <p style="color: #666; margin-bottom: 20px; font-weight: 500;">Please have this QR code ready to scan at the gate.</p>
      
      <div style="background: #fff; padding: 15px; display: inline-block; border-radius: 10px; border: 1px solid #eee;">
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data={{ customer.metafields.custom.ticket_id }}" 
             alt="Ticket QR Code" style="display: block; margin: 0 auto;">
      </div>
      
      <div style="margin-top: 25px;">
        <span style="font-family: monospace; font-size: 1.2em; font-weight: bold; background: #000; color: #fff; padding: 8px 20px; border-radius: 5px; letter-spacing: 3px;">
          {{ customer.metafields.custom.ticket_id }}
        </span>
      </div>
      <p style="margin-top: 15px; font-size: 0.8em; color: #999; text-transform: uppercase; letter-spacing: 1px;">Valid for One Entry Only</p>
    </div>
  {% endif %}
{% endif %}
  </body>
</html>
