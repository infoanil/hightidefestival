{% comment %}
  This section is used in the list-collections template to render a list of
  products from the current collection.
{% endcomment %}

{%- comment -%}
  Set the collection object and pagination limit
{%- endcomment -%}
{% assign collection_to_display = collection %}
{% if collection_to_display == blank %}
  {% assign collection_to_display = collections[section.settings.featured_collection] %}
{% endif %}{% assign products_per_page = section.settings.product_limit | default: 16 %}

{%- comment -%}
  Dynamic Grid Classes based on settings
{%- endcomment -%}
{% assign col_desk = section.settings.columns_desktop | default: 4 %}
{% assign col_mobile = section.settings.columns_mobile | default: 2 %}
{% assign grid_gap = section.settings.grid_gap | default: 10 %}

{% assign grid_classes = 'grid-cols-' | append: col_mobile | append: ' lg:grid-cols-' | append: col_desk %}
{% assign gap_classes = 'gap-x-' | append: grid_gap | append: ' gap-y-10' %}

  <div x-data="{ mobileFiltersOpen: false }" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10 text-secondary">
  
  <span class="text-secondary-navy">{% render 'breadcrumb', class:'flex justify-center md:justify-start' %}</span>

  {% comment %} --- Title  --- {% endcomment %}
  {% if collection_to_display %}
    <h1 class="mt-3 text-center md:text-left text-[35px] leading-[36px] md:text-[60px] md:leading-[61px] lg:text-[80px] lg:leading-[74px] tracking-[-1px] font-amaya uppercase text-secondary-navy">{{ collection_to_display.title }}</h1>
  {% else %}
    <h1 class="pt-4 mb-8 text-3xl font-bold">{{ section.settings.heading_text }}</h1>
  {% endif %}
  <div class="text-center md:text-left text-lg text-secondary-navy mt-2 uppercase tracking-[-1px]">{{ collection.description }}</div>

  <hr class="mt-7.5 mb-3">


  <div class="mb-4 md:mb-9 flex pb-3 justify-between border-b ">
    {% comment %} Filters Toggle {% endcomment %}
    <button @click="mobileFiltersOpen = true" class="flex items-center cursor-pointer gap-2 font-bold text-sm md:text-lg uppercase text-secondary-navy border border-[#2D2D2D4D] px-3 py-2">
      Show filters
      <svg width="5" height="8" viewBox="0 0 5 8" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3.18205 4L1.05982e-08 0.888749L0.908974 4.8785e-08L5 4L0.908974 8L8.48008e-08 7.11125L3.18205 4Z" fill="#2D2D2D"/>
      </svg>

    </button>
    {% comment %} Sort by {% endcomment %}
    <div x-data="{ sort: '{{ collection.sort_by | default: collection.default_sort_by }}' }" class="flex items-center text-xs md:text-[15px]">
        <label for="sort-by" class="mr-2 uppercase font-bold text-sm md:text-lg text-[#555555] tracking-[-1px ] whitespace-nowrap">{{ section.settings.sort_by_label | default: 'Sort by:' }}</label>
        <select id="sort-by" x-model="sort" @change="window.location.search = '?sort_by=' + sort" class="w-[120px] md:w-auto uppercase text-sm md:text-lg font-bold bg-transparent rounded-none py-3 focus:border-none focus-visible:!border-none">
            {% for option in collection.sort_options %}
            <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>{{ option.name }}</option>
            {% endfor %}
        </select>
    </div>
  </div>



  {% comment %} --- Main Content Layout: Filters and Products --- {% endcomment %}
  <div class="flex flex-col lg:space-x-10">

    {% comment %} --- Backdrop Overlay --- {% endcomment %}
    <div
      x-show="mobileFiltersOpen"
      @click="mobileFiltersOpen = false"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      class="fixed inset-0 z-40 bg-black/50"
      aria-hidden="true">
    </div>

    {% comment %} --- Filter Drawer --- {% endcomment %}
    <div
      x-show="mobileFiltersOpen"
      @keydown.escape.window="mobileFiltersOpen = false"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0 -translate-x-full"
      x-transition:enter-end="opacity-100 translate-x-0"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100 translate-x-0"
      x-transition:leave-end="opacity-0 -translate-x-full"
      class="fixed inset-y-0 left-0 z-50 transform bg-bg-color p-4 w-full max-w-[400px] overflow-y-auto"
      role="dialog"
      aria-modal="true"
      @click.outside="mobileFiltersOpen = false">

      <div class="flex items-center justify-between border-b pb-4">
        <h2 class="text-lg font-extrabold uppercase tracking-[-1px] text-secondary-navy">{{ section.settings.filter_heading | default: 'Filter Products' }}</h2>
        <button @click="mobileFiltersOpen = false" class="-mr-2 flex h-10 w-10 items-center justify-center rounded-md bg-white p-2 text-gray-400">
          <svg
            class="h-6 w-6"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            aria-hidden="true">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      {% comment %} Renders the filter content structure inside the drawer. {% endcomment %}
      <div id="CollectionFiltersMobile">
        {% render 'collection-filters'
          , current_collection: collection_to_display %}
      </div>
    </div>

    <div class="w-full" id="ProductGridContainer">

      {% paginate collection_to_display.products by products_per_page %}

        {% comment %} --- Product Grid (Dynamic Columns) --- {% endcomment %}
        <div class="grid {{ grid_classes }}" style="column-gap: {{ grid_gap | times: 4 }}px; row-gap: 40px;">


          {% comment %} Loop uses the paginated products object {% endcomment %}
          {% if collection_to_display and collection_to_display.products.size > 0 %}
            {% for product in collection_to_display.products %}
              <div>
                {% render 'product-card'
                  , product: product
                  , show_swatches: section.settings.show_swatches
                  , show_rating: section.settings.show_rating
                  , show_quick_add: section.settings.show_quick_add
                  , show_compare_price: section.settings.show_compare_price %}
              </div>
            {% endfor %}
          {% else %}
            <p style="text-align: center; grid-column: 1 / -1;">
              {% if collection_to_display == blank %}
                Please select a collection in the section settings.
              {% else %}
                No products found in this collection.
              {% endif %}
            </p>
          {% endif %}
        </div>

        <div class="mt-12">
          {% render 'pagination'
            , paginate: paginate %}
        </div>

      {% endpaginate %}

    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // 1. Get ALL filter forms using a class selector
    const filterForms = document.querySelectorAll(".js-filter-form");
    const productGrid = document.querySelector("#ProductGridContainer");

    if (!productGrid || filterForms.length === 0) return;

    
    function bindFilterEvents() {
      const filterForms = document.querySelectorAll(".js-filter-form");
      filterForms.forEach(form => {
        form.addEventListener("change", handleFilterChange);
      });
    }

    const handleFilterChange = (event) => {
      const filterForm = event.currentTarget;
      event.preventDefault();

      const formData = new FormData(filterForm);
      const params = new URLSearchParams(formData);

      for (const [key, value] of params.entries()) {
      if (!value) {
        params.delete(key);
      }
      }

      const searchParams = params.toString();
      
      productGrid.classList.add("opacity-50");

      // Fetch the current section with updated filters
      fetch(`${window.location.pathname}?${searchParams}&section_id={{ section.id }}`)
        .then((response) => response.text())
        .then((html) => {
          // Parse and replace only the product grid
          const parser = new DOMParser();
          const newDoc = parser.parseFromString(html, "text/html");
          const newGrid = newDoc.querySelector("#ProductGridContainer");
          // Replace DESKTOP filters
          const filterContainer = document.querySelector("#CollectionFilters");
          const newFilters = newDoc.querySelector("#CollectionFilters");

          if (filterContainer && newFilters) {
              filterContainer.innerHTML = newFilters.innerHTML;
              }
          // Replace MOBILE filters
          const filterContainerMobile = document.querySelector("#CollectionFiltersMobile");
          const newFiltersMobile = newDoc.querySelector("#CollectionFiltersMobile");

          if (filterContainerMobile && newFiltersMobile) {
              filterContainerMobile.innerHTML = newFiltersMobile.innerHTML;
              }

              bindFilterEvents();

          if (newGrid) {
            productGrid.innerHTML = newGrid.innerHTML;
            productGrid.classList.remove("opacity-50");
            window.history.replaceState({}, "", `${window.location.pathname}?${searchParams}`);
            
            
            // This is how you access and manipulate the Alpine state from outside
            const alpineContainer = document.querySelector('[x-data="{ mobileFiltersOpen: false }"]');
            if (alpineContainer && alpineContainer.__x) {
                alpineContainer.__x.data.mobileFiltersOpen = false;
            }
          }
        })
        .catch((err) => console.error("Filter fetch error:", err));
    };

    // 3. Attach the event listener to EACH form found
    filterForms.forEach(form => {
      form.addEventListener("change", handleFilterChange);
    });
    bindFilterEvents();
  });
</script>

{% schema %}
  {
    "name": "collection",
    "settings": [
      {
        "type": "collection",
        "id": "featured_collection",
        "label": "Collection to display"
      },
      {
        "type": "text",
        "id": "heading_text",
        "label": "Section Heading",
        "default": "Feature Products"
      },
      {
        "type": "text",
        "id": "filter_heading",
        "label": "Filter Section Heading",
        "default": "Filter Products",
        "info": "This heading is used for both desktop filters and the mobile drawer."
      },
      {
        "type": "range",
        "id": "product_limit",
        "min": 1,
        "max": 50,
        "step": 1,
        "label": "Products per page",
        "default": 16
      }, {
        "type": "range",
        "id": "columns_desktop",
        "label": "Products per row (Desktop)",
        "min": 2,
        "max": 5,
        "step": 1,
        "default": 4
      }, {
        "type": "range",
        "id": "columns_mobile",
        "label": "Products per row (Mobile)",
        "min": 1,
        "max": 3,
        "step": 1,
        "default": 2
      }, {
        "type": "range",
        "id": "grid_gap",
        "label": "Grid spacing (Tailwind scale: 1-12)",
        "min": 1,
        "max": 12,
        "step": 1,
        "default": 4,
        "info": "Uses the Tailwind spacing scale (1 = 4px, 12 = 48px)."
      }, {
        "type": "checkbox",
        "id": "show_rating",
        "label": "Show product ratings",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_swatches",
        "label": "Show color swatches",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_quick_add",
        "label": "Show Quick Add button",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_compare_price",
        "label": "Show compare-at price",
        "default": true
      }

    ],
    "presets": [
      {
        "name": "Collection"
      }
    ]
  }
{% endschema %}