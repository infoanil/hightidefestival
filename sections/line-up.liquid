{%- style -%}
  #shopify-section-{{ section.id }} .section-line-up__wrapper {
    background-color: {{ section.settings.section_background_color_mobile | default: section.settings.section_background_color }};
  }
  #shopify-section-{{ section.id }} .section-line-up__legend {
    font-size: {{ section.settings.legend_font_size_mobile }}px;
    font-weight: {{ section.settings.legend_font_weight }};
  }
  #shopify-section-{{ section.id }} .section-line-up__heading {
    font-size: {{ section.settings.heading_font_size_mobile }}px;
    line-height: {{ section.settings.heading_line_height_mobile }}px;
    font-weight: {{ section.settings.heading_font_weight }};
  }
  #shopify-section-{{ section.id }} .artist-name {
    font-size: var(--fs-mobile);
  }
  #shopify-section-{{ section.id }} .section-line-up__footer-button-v2 {
    align-items: center;
    justify-content: center;
    padding: 10px 20px;
    border-radius: 5px;
    background-color: #e6772a;
    color: #ffffff;
    font-size: 15px;
    font-weight: 800;
    line-height: 1.5;
    text-align: center;
    text-transform: uppercase;
    white-space: nowrap;
    transition: transform 180ms ease, background-color 180ms ease;
  }
  #xdshopify-section-{{ section.id }} .section-line-up__footer-button-v2:hover,
  #shopify-section-{{ section.id }} .section-line-up__footer-button-v2:focus-visible {
    background-color: #d56c25;
    transform: translateY(-2px);
  }
  #shopify-section-{{ section.id }} .section-line-up__footer-button-v2:focus-visible {
    outline: 2px solid #0b4166;
    outline-offset: 3px;
  }
  @media (min-width: 48rem) {
    #shopify-section-{{ section.id }} .section-line-up__wrapper {
      background-color: {{ section.settings.section_background_color_desktop | default: section.settings.section_background_color_mobile | default: section.settings.section_background_color }};
    }
    #shopify-section-{{ section.id }} .section-line-up__legend {
      font-size: {{ section.settings.legend_font_size_desktop }}px;
    }
    #shopify-section-{{ section.id }} .section-line-up__heading {
      font-size: {{ section.settings.heading_font_size_desktop }}px;
      line-height: {{ section.settings.heading_line_height_desktop }}px;
    }
  }
  @media (min-width: 64rem) {
    #shopify-section-{{ section.id }} .artist-name {
      font-size: var(--fs-desktop);
    }
  }
  #shopify-section-{{ section.id }} li.is-active {
    translate: -0.5rem -0.5rem;
    z-index: 1;
    background-color: #FCE0EC;
    box-shadow: 8px 8px 0px 0 rgba(0, 0, 0, 1);
    border-top-right-radius: 5px;
  }
  #shopify-section-{{ section.id }} li.is-active .artist-image {
    opacity: 1;
    visibility: visible;
    scale: 1;
    rotate: 0deg;
  }
{%- endstyle -%}

<div id="line-up" class="section-line-up__wrapper flex flex-wrap py-10 lg:py-20">
  <div class="container mx-auto px-4" x-data="{ activeBlock: null }">

    <div class="headings flex flex-row justify-between items-end mb-8 md:mb-12 text-secondary-navy md:pb-6 md:border-b md:border-secondary-navy gap-4">
      
      <div class="flex-1">
        <p class="section-line-up__legend legend uppercase mb-2 md:mb-4 tracking-[-1px] md:hidden">
          {{ section.settings.legend_mobile | default: section.settings.legend | default: 'the line ups' }}
        </p>
        <p class="section-line-up__legend legend uppercase mb-2 md:mb-4 tracking-[-1px] hidden md:block">
          {{ section.settings.legend_desktop | default: section.settings.legend_mobile | default: section.settings.legend | default: 'the line ups' }}
        </p>
        <h2 class="section-line-up__heading font-amaya uppercase tracking-[-1px] text-balance md:hidden">
          {{ section.settings.heading_mobile | default: section.settings.heading | default: "The Sound of High Tide" }}
        </h2>
        <h2 class="section-line-up__heading font-amaya uppercase tracking-[-1px] text-balance hidden md:block">
          {{ section.settings.heading_desktop | default: section.settings.heading_mobile | default: section.settings.heading | default: "The Sound of High Tide" }}
        </h2>
      </div>

      {% assign lineups_by_day_link_mobile = section.settings.lineups_by_day_link_mobile | default: section.settings.lineups_by_day_link %}
      {% assign lineups_by_day_link_desktop = section.settings.lineups_by_day_link_desktop | default: section.settings.lineups_by_day_link_mobile | default: section.settings.lineups_by_day_link %}
      {% assign lineups_by_day_text_mobile = section.settings.lineups_by_day_text_mobile | default: section.settings.lineups_by_day_text | default: 'LINEUPS BY DAY' %}
      {% assign lineups_by_day_text_desktop = section.settings.lineups_by_day_text_desktop | default: section.settings.lineups_by_day_text_mobile | default: section.settings.lineups_by_day_text | default: 'LINEUPS BY DAY' %}

      {% if lineups_by_day_link_mobile != blank or lineups_by_day_link_desktop != blank %}
        <div class="flex shrink-0 items-center">
          <a href="{{ lineups_by_day_link_mobile }}"
             class="inline-flex md:hidden px-4 py-2 uppercase text-[10px] font-bold rounded-full bg-secondary-navy text-white hover:bg-opacity-90 transition-all duration-200 cursor-pointer whitespace-nowrap border border-secondary-navy hover:bg-trietary-orange hover:scale-105 hover:border-trietary-orange">
            {{ lineups_by_day_text_mobile }}
          </a>
          <a href="{{ lineups_by_day_link_desktop }}"
             class="hidden md:block md:px-8 md:py-3 uppercase md:text-lg font-bold rounded-full bg-secondary-navy text-white hover:bg-opacity-90 transition-all duration-200 cursor-pointer whitespace-nowrap border border-secondary-navy hover:bg-trietary-orange hover:scale-105 hover:border-trietary-orange">
            {{ lineups_by_day_text_desktop }}
          </a>
        </div>
      {% endif %}
    </div>

    <ul class="flex flex-wrap">
      {% for block in section.blocks %}
        {%- assign block_link = block.settings.link -%}
        <li
          @click="window.innerWidth < 700 && (activeBlock = activeBlock === '{{ block.id }}' ? null : '{{ block.id }}')"
          :class="{ 'is-active': activeBlock === '{{ block.id }}' }"
          {{ block.shopify_attributes }}
          class="group relative flex items-center justify-center gap-[10px] px-[10px] py-3 lg:px-[18px] lg:h-[75px] outline outline-secondary-navy bg-bg-color hover:-translate-x-2 hover:-translate-y-2 hover:z-1 hover:bg-[#FCE0EC] hover:shadow-[8px_8px_0px_0_rgba(0,0,0,1)] hover:rounded-tr-[5px] transition-all duration-200 cursor-pointer w-fit"
          style="--fs-mobile: {{ block.settings.font_size_mobile }}rem; --fs-desktop: {{ block.settings.font_size_desktop }}rem; color: {{ block.settings.name_color }}">

          <span class="artist-name tracking-[-1px] leading-1 uppercase font-amaya flex items-center h-full">
            {{ block.settings.name }}
          </span>

          {% if block.settings.icon != blank %}
            <img
              src="{{ block.settings.icon | image_url: width: 80 }}"
              alt=""
              width="40"
              height="40"
              class="w-[1em] h-[1em] lg:w-[2rem] lg:h-[2rem] object-contain shrink-0">
          {% endif %}

          {% if block.settings.hover_image != blank %}
            {%- assign image_shape_class = '' -%}
            {%- if block.settings.image_shape == 'square' -%}
              {%- assign image_shape_class = 'aspect-square' -%}
            {%- endif -%}

            {% capture hover_content %}
              <img
                src="{{ block.settings.hover_image | image_url: width: 1200 }}"
                alt="{{ block.settings.name }}"
                width="1200"
                height="1200"
                class="w-full h-full object-cover">
            {% endcapture %}

            {% if block_link != blank %}
              <a href="{{ block_link }}" class="artist-image pointer-events-auto w-full {{ image_shape_class }} rounded-[20px] overflow-hidden invisible absolute left-0 top-[110%] opacity-0 scale-50 rotate-45 group-hover:opacity-100 group-hover:visible group-hover:scale-100 group-hover:rotate-0 transition duration-300 z-[10] ease-in-out">
                {{ hover_content }}
              </a>
            {% else %}
              <div class="artist-image pointer-events-auto w-full {{ image_shape_class }} rounded-[20px] overflow-hidden invisible absolute left-0 top-[110%] opacity-0 scale-50 rotate-45 group-hover:opacity-100 group-hover:visible group-hover:scale-100 group-hover:rotate-0 transition duration-300 z-[10] ease-in-out">
                {{ hover_content }}
              </div>
            {% endif %}
          {% endif %}
        </li>
      {% endfor %}

      {% if section.blocks.size > 0 %}
        {% assign use_footer_button_v2_mobile = section.settings.footer_button_v2_mobile %}
        {% assign use_footer_button_v2_desktop = section.settings.footer_button_v2_desktop %}

        {% if use_footer_button_v2_mobile and use_footer_button_v2_desktop %}
          <li class="w-full flex justify-center pt-4 md:pt-6">
            <a
              {% if section.settings.footer_link_mobile != blank or section.settings.footer_link_desktop != blank or section.settings.footer_link != blank %}href="{{ section.settings.footer_link_mobile | default: section.settings.footer_link_desktop | default: section.settings.footer_link }}"{% endif %}
              class="section-line-up__footer-button-v2 inline-flex font-extrabold cursor-pointer">
              {{ section.settings.footer_label_mobile | default: section.settings.footer_label_desktop | default: section.settings.footer_label | default: 'view full schedule' }}
            </a>
          </li>
        {% elsif use_footer_button_v2_mobile %}
          <li class="w-full pt-4 md:pt-6">
            <a
              {% if section.settings.footer_link_mobile != blank or section.settings.footer_link != blank %}href="{{ section.settings.footer_link_mobile | default: section.settings.footer_link }}"{% endif %}
              class="section-line-up__footer-button-v2 inline-flex font-extrabold cursor-pointer md:hidden mx-auto">
              {{ section.settings.footer_label_mobile | default: section.settings.footer_label | default: 'view full schedule' }}
            </a>

            <div class="hidden md:block">
              <div class="w-full bg-[#0B4166]" style="--fs-mobile: 1.3rem; --fs-desktop: 3.1rem">
                <a
                  {% if section.settings.footer_link_desktop != blank or section.settings.footer_link != blank %}href="{{ section.settings.footer_link_desktop | default: section.settings.footer_link }}"{% endif %}
                  class="group/footer flex items-center justify-center gap-3 px-[10px] py-3 lg:p-5 w-full cursor-pointer">
                  <span class="artist-name font-amaya leading-1 text-[#FDFAF5] tracking-[-1px] uppercase">{{ section.settings.footer_label_desktop | default: section.settings.footer_label | default: 'view full schedule' }}</span>
                  <svg class="transition-transform duration-200 lg:group-hover/footer:translate-x-2" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none">
                    <path d="M18 12L5 12M18 12L14 16M18 12L14 8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            </div>
          </li>
        {% elsif use_footer_button_v2_desktop %}
          <li class="w-full pt-4 md:pt-6">
            <div class="md:hidden w-full bg-[#0B4166]" style="--fs-mobile: 1.3rem; --fs-desktop: 3.1rem">
              <a
                {% if section.settings.footer_link_mobile != blank or section.settings.footer_link != blank %}href="{{ section.settings.footer_link_mobile | default: section.settings.footer_link }}"{% endif %}
                class="group/footer flex items-center justify-center gap-3 px-[10px] py-3 lg:p-5 w-full cursor-pointer">
                <span class="artist-name font-amaya leading-1 text-[#FDFAF5] tracking-[-1px] uppercase">{{ section.settings.footer_label_mobile | default: section.settings.footer_label | default: 'view full schedule' }}</span>
                <svg class="transition-transform duration-200 lg:group-hover/footer:translate-x-2" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none">
                  <path d="M18 12L5 12M18 12L14 16M18 12L14 8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>

            <a
              {% if section.settings.footer_link_desktop != blank or section.settings.footer_link != blank %}href="{{ section.settings.footer_link_desktop | default: section.settings.footer_link }}"{% endif %}
              class="section-line-up__footer-button-v2 font-extrabold cursor-pointer hidden md:flex w-fit mx-auto">
              {{ section.settings.footer_label_desktop | default: section.settings.footer_label | default: 'view full schedule' }}
            </a>
          </li>
        {% else %}
          <li class="w-full bg-[#0B4166]" style="--fs-mobile: 1.3rem; --fs-desktop: 3.1rem">
            <a
              {% if section.settings.footer_link_mobile != blank or section.settings.footer_link != blank %}href="{{ section.settings.footer_link_mobile | default: section.settings.footer_link }}"{% endif %}
              class="group/footer flex items-center justify-center gap-3 px-[10px] py-3 lg:p-5 w-full cursor-pointer md:hidden">
              <span class="artist-name font-amaya leading-1 text-[#FDFAF5] tracking-[-1px] uppercase">{{ section.settings.footer_label_mobile | default: section.settings.footer_label | default: 'view full schedule' }}</span>
              <svg class="transition-transform duration-200 lg:group-hover/footer:translate-x-2" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none">
                <path d="M18 12L5 12M18 12L14 16M18 12L14 8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a
              {% if section.settings.footer_link_desktop != blank or section.settings.footer_link != blank %}href="{{ section.settings.footer_link_desktop | default: section.settings.footer_link }}"{% endif %}
              class="group/footer hidden md:flex items-center justify-center gap-3 px-[10px] py-3 lg:p-5 w-full cursor-pointer">
              <span class="artist-name font-amaya leading-1 text-[#FDFAF5] tracking-[-1px] uppercase">{{ section.settings.footer_label_desktop | default: section.settings.footer_label | default: 'view full schedule' }}</span>
              <svg class="transition-transform duration-200 lg:group-hover/footer:translate-x-2" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none">
                <path d="M18 12L5 12M18 12L14 16M18 12L14 8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        {% endif %}
      {% endif %}
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "Line Up",
  "tag": "section",
  "class": "section-line-up",
  "settings": [
    {
      "type": "text",
      "id": "legend",
      "label": "Legend",
      "default": "the line ups"
    },
    {
      "type": "text",
      "id": "legend_mobile",
      "label": "Legend (mobile)",
      "default": "the line ups"
    },
    {
      "type": "text",
      "id": "legend_desktop",
      "label": "Legend (desktop)",
      "default": "the line ups"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Sound of High Tide"
    },
    {
      "type": "text",
      "id": "heading_mobile",
      "label": "Heading (mobile)",
      "default": "The Sound of High Tide"
    },
    {
      "type": "text",
      "id": "heading_desktop",
      "label": "Heading (desktop)",
      "default": "The Sound of High Tide"
    },
    {
      "type": "color",
      "id": "section_background_color_mobile",
      "label": "Background color (mobile)",
      "default": "#f6f5f0"
    },
    {
      "type": "color",
      "id": "section_background_color_desktop",
      "label": "Background color (desktop)",
      "default": "#f6f5f0"
    },
    {
      "type": "header",
      "content": "Legend typography"
    },
    {
      "type": "range",
      "id": "legend_font_size_mobile",
      "label": "Legend font size (mobile)",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "legend_font_size_desktop",
      "label": "Legend font size (desktop)",
      "min": 10,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "select",
      "id": "legend_font_weight",
      "label": "Legend font weight",
      "default": "700",
      "options": [
        { "value": "100", "label": "Thin" },
        { "value": "200", "label": "Extra light" },
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extrabold" },
        { "value": "900", "label": "Black" }
      ]
    },
    {
      "type": "header",
      "content": "Heading typography"
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading font size (mobile)",
      "min": 24,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_line_height_mobile",
      "label": "Heading line height (mobile)",
      "min": 24,
      "max": 90,
      "step": 1,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "heading_font_size_desktop",
      "label": "Heading font size (desktop)",
      "min": 32,
      "max": 140,
      "step": 2,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "heading_line_height_desktop",
      "label": "Heading line height (desktop)",
      "min": 32,
      "max": 140,
      "step": 2,
      "unit": "px",
      "default": 88
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading font weight",
      "default": "400",
      "options": [
        { "value": "100", "label": "Thin" },
        { "value": "200", "label": "Extra light" },
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "header",
      "content": "Header Button (Right Side)"
    },
    {
      "type": "text",
      "id": "lineups_by_day_text",
      "label": "Button Label",
      "default": "LINEUPS BY DAY"
    },
    {
      "type": "text",
      "id": "lineups_by_day_text_mobile",
      "label": "Button Label (mobile)",
      "default": "+ MANY MORE! →"
    },
    {
      "type": "text",
      "id": "lineups_by_day_text_desktop",
      "label": "Button Label (desktop)",
      "default": "All Products"
    },
    {
      "type": "url",
      "id": "lineups_by_day_link",
      "label": "Button Link"
    },
    {
      "type": "url",
      "id": "lineups_by_day_link_mobile",
      "label": "Button Link (mobile)"
    },
    {
      "type": "url",
      "id": "lineups_by_day_link_desktop",
      "label": "Button Link (desktop)"
    },
    {
      "type": "header",
      "content": "Footer Settings"
    },
    {
      "type": "text",
      "id": "footer_label",
      "label": "Footer Label",
      "default": "view full schedule"
    },
    {
      "type": "text",
      "id": "footer_label_mobile",
      "label": "Footer Label (mobile)",
      "default": "BUY PASSES"
    },
    {
      "type": "text",
      "id": "footer_label_desktop",
      "label": "Footer Label (desktop)",
      "default": "BUY PASSES"
    },
    {
      "type": "checkbox",
      "id": "footer_button_v2_mobile",
      "label": "Use button v2 style on mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "footer_button_v2_desktop",
      "label": "Use button v2 style on desktop",
      "default": false
    },
    {
      "type": "url",
      "id": "footer_link",
      "label": "Footer Link"
    },
    {
      "type": "url",
      "id": "footer_link_mobile",
      "label": "Footer Link (mobile)"
    },
    {
      "type": "url",
      "id": "footer_link_desktop",
      "label": "Footer Link (desktop)"
    }
  ],
  "blocks": [
    {
      "type": "artist",
      "name": "Artist",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Artist Name"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "color",
          "id": "name_color",
          "label": "Name Color",
          "default": "#0b4166"
        },
        {
          "type": "image_picker",
          "id": "hover_image",
          "label": "Hover Image"
        },
        {
          "type": "select",
          "id": "image_shape",
          "label": "Image Shape",
          "options": [
            { "value": "rectangular", "label": "Rectangular" },
            { "value": "square", "label": "Square" }
          ],
          "default": "square"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "range",
          "id": "font_size_mobile",
          "label": "Font Size (Mobile)",
          "min": 0.5,
          "max": 5,
          "step": 0.1,
          "unit": "rem",
          "default": 1.3
        },
        {
          "type": "range",
          "id": "font_size_desktop",
          "label": "Font Size (Desktop)",
          "min": 0.5,
          "max": 5,
          "step": 0.1,
          "unit": "rem",
          "default": 3.1
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Line Up"
    }
  ]
}
{% endschema %}
