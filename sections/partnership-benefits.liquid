{% comment %}
  Partnership Benefits Section
  - Three-column icon grid showcasing sponsorship value propositions
  - Each block: custom icon image, bold title, description
  - Desktop: 3 columns | Mobile: stacked
{% endcomment %}

<style>
  #section-partnership-benefits-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media (min-width: 768px) {
    #section-partnership-benefits-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }
</style>

<section
  id="section-partnership-benefits-{{ section.id }}"
  aria-labelledby="partnership-benefits-heading-{{ section.id }}"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    {% if section.settings.heading != blank %}
      <h2
        id="partnership-benefits-heading-{{ section.id }}"
        class="text-center text-2xl sm:text-3xl font-bold uppercase tracking-wide mb-10"
        style="color: {{ section.settings.heading_color }};"
      >
        {{ section.settings.heading | escape }}
      </h2>
    {% endif %}

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10" role="list">
      {% for block in section.blocks %}
        <div
          class="flex flex-col items-center text-center s"
          role="listitem"
          {{ block.shopify_attributes }}
        >

          {% if block.settings.icon != blank %}
            <div class="flex items-center justify-center h-15 w-auto mb-6" aria-hidden="true">
              {{
                block.settings.icon
                | image_url: width: 160
                | image_tag: loading: 'lazy', alt: '', class: 'h-full w-full object-contain'
              }}
            </div>
          {% endif %}
          
          {% if block.settings.title != blank %}
            <h3
              class="type-heading-5 mb-3"
              style="color: {{ block.settings.title_color }};"
            >
              {{ block.settings.title | escape }}
            </h3>
          {% endif %}

          {% if block.settings.description != blank %}
            <p class="type-body text-secondary-navy" style="color: {{ block.settings.description_color }};">
              {{ block.settings.description }}
            </p>
          {% endif %}

        </div>
      {% endfor %}
    </div>

  </div>
</section>


{% schema %}
{
  "name": "Partnership Benefits",
  "tag": "section",
  "class": "section-partnership-benefits",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 40
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "benefit_item",
      "name": "Benefit Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit Title"
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Title Color",
          "default": "#0b4166"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Describe this sponsorship benefit here."
        },
        {
          "type": "color",
          "id": "description_color",
          "label": "Description Color",
          "default": "#374151"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Partnership Benefits",
      "category": "Sponsorship",
      "blocks": [
        {
          "type": "benefit_item",
          "settings": {
            "title": "Engaged Music Audience",
            "description": "Connect with a highly engaged community of music fans, creators, and cultural tastemakers."
          }
        },
        {
          "type": "benefit_item",
          "settings": {
            "title": "Brand Activations",
            "description": "Create immersive brand experiences, on-site activations, and memorable moments with festival attendees."
          }
        },
        {
          "type": "benefit_item",
          "settings": {
            "title": "Multi-Channel Exposure",
            "description": "Amplify your brand through festival stages, digital promotion, social media, and live event visibility."
          }
        }
      ]
    }
  ]
}
{% endschema %}
