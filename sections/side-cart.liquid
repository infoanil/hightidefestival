{%- liquid
  assign component_id = 'side-cart-' | append: section.id
  assign has_offer_items = false
  assign has_upgrade_items = false
  assign show_additions_section = false

  for i in (1..5)
    assign product_key = 'offer_product_' | append: i
    if section.settings[product_key] != blank
      assign has_offer_items = true
    endif
  endfor

  for item in cart.items
    if item.product.metafields.custom.ab_test_upsell.value != blank
      assign has_upgrade_items = true
    endif
  endfor

  if cart.item_count > 0
    if has_upgrade_items or has_offer_items
      assign show_additions_section = true
    endif
  endif
-%}

<style>
  #{{ component_id }} {
    --side-cart-border: rgba(11, 65, 102, 0.4);
    --side-cart-divider: #dfe6eb;
    --side-cart-muted: rgba(11, 65, 102, 0.8);
    --side-cart-shadow: -24px 0 48px rgba(17, 24, 39, 0.12);
    --side-cart-width: min(100vw, 430px);
    --side-cart-image-size: 96px;
    --side-cart-pill-radius: 99999px;
    --side-cart-ink: #0b4166;
    --side-cart-surface: #fefaf6;
  }

  body.ht-side-cart-active #candyrack-slider-cart,
  body.ht-side-cart-active [id^="candyrack"],
  body.ht-side-cart-active [class*="candyrack-slider-cart"],
  body.ht-side-cart-active [class*="candyrack-cart"] {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }

  #{{ component_id }} [x-cloak] {
    display: none !important;
  }

  #{{ component_id }} .ht-side-cart__layer {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
  }

  #{{ component_id }} .ht-side-cart__layer.is-open {
    pointer-events: auto;
  }

  #{{ component_id }} .ht-side-cart__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(17, 24, 39, 0.36);
  }

  #{{ component_id }} .ht-side-cart__panel {
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    width: var(--side-cart-width);
    max-width: 100%;
    background: var(--side-cart-surface);
    box-shadow: var(--side-cart-shadow);
    display: flex;
    flex-direction: column;
    color: var(--side-cart-ink);
  }

  #{{ component_id }} .ht-side-cart__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 18px;
    border-bottom: 1px solid var(--side-cart-divider);
  }

  #{{ component_id }} .ht-side-cart__title {
    margin: 0;
    font-size: 18px;
    line-height: 1.1;
    font-weight: 700;
    letter-spacing: 0;
    color: var(--side-cart-ink);
  }

  #{{ component_id }} .ht-side-cart__close {
    border: 0;
    background: transparent;
    width: 40px;
    height: 40px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--side-cart-ink);
    cursor: pointer;
    opacity: 0.8;
  }

  #{{ component_id }} .ht-side-cart__content {
    position: relative;
    display: flex;
    flex: 1;
    min-height: 0;
    flex-direction: column;
  }

  #{{ component_id }} .ht-side-cart__scroll {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    overflow-y: auto;
  }

  #{{ component_id }} .ht-side-cart__loading {
    position: absolute;
    inset: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(3px);
  }

  #{{ component_id }} .ht-side-cart__spinner {
    width: 28px;
    height: 28px;
    border: 2px solid rgba(31, 41, 55, 0.15);
    border-top-color: #1f2937;
    border-radius: 999px;
    animation: ht-side-cart-spin 0.8s linear infinite;
  }

  #{{ component_id }} .ht-side-cart__items {
    display: flex;
    flex-direction: column;
    padding: 0 18px;
    background: var(--side-cart-surface);
  }

  #{{ component_id }} .ht-side-cart__item {
    display: grid;
    grid-template-columns: var(--side-cart-image-size) minmax(0, 1fr);
    gap: 16px;
    padding: 24px 0;
    border-bottom: 1px solid var(--side-cart-divider);
    background: var(--side-cart-surface);
  }

  #{{ component_id }} .ht-side-cart__item-stack {
    display: flex;
    flex-direction: column;
    /*border-bottom: 1px solid var(--side-cart-divider);*/
  }

  #{{ component_id }} .ht-side-cart__item-stack > .ht-side-cart__item {
    border-bottom: 0;
  }

  #{{ component_id }} .ht-side-cart__item-media {
    width: var(--side-cart-image-size);
    height: var(--side-cart-image-size);
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
  }

  #{{ component_id }} .ht-side-cart__item-media img,
  #{{ component_id }} .ht-side-cart__offer-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #{{ component_id }} .ht-side-cart__upgrade {
    margin: 20px 18px 0;
    border: 1px solid rgba(11, 65, 102, 0.13);
    border-radius: 5px;
    background: #fff;
    padding: 18px;
  }

  #{{ component_id }} .ht-side-cart__additions {
    background: #fff;
    border-top: 1px solid var(--side-cart-divider);
    display: flex;
    flex: 1 0 auto;
    flex-direction: column;
  }

  #{{ component_id }} .ht-side-cart__additions-inner {
    background: #fff;
    display: flex;
    flex: 1 0 auto;
    flex-direction: column;
  }

  #{{ component_id }} .ht-side-cart__upgrade-title {
    margin: 0;
    font-size: 17px;
    line-height: 20px;
    font-weight: 700;
    color: var(--side-cart-ink);
  }

  #{{ component_id }} .ht-side-cart__upgrade-row {
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr) auto;
    gap: 16px;
    align-items: center;
    min-height: 96px;
    padding-top: 20px;
  }

  #{{ component_id }} .ht-side-cart__upgrade-media {
    width: 96px;
    height: 96px;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
  }

  #{{ component_id }} .ht-side-cart__upgrade-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #{{ component_id }} .ht-side-cart__upgrade-copy {
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 96px;
  }

  #{{ component_id }} .ht-side-cart__upgrade-name {
    margin: 0;
    font-size: 16px;
    line-height: 20px;
    font-weight: 700;
    color: var(--side-cart-ink);
  }

  #{{ component_id }} .ht-side-cart__upgrade-price {
    margin-top: 0;
    font-size: 16px;
    line-height: 20px;
    font-weight: 700;
    color: var(--side-cart-ink);
  }

  #{{ component_id }} .ht-side-cart__upgrade-action {
    min-height: 96px;
    display: flex;
    align-items: center;
  }

  #{{ component_id }} .ht-side-cart__upgrade-button {
    border: 0;
    border-radius: 99999px;
    background: #0c4166;
    color: #fff;
    cursor: pointer;
    padding: 10px 20px;
    font-size: 14px;
    line-height: 20px;
    font-weight: 600;
    white-space: nowrap;
    transition: background-color 0.2s ease, opacity 0.2s ease;
  }

  #{{ component_id }} .ht-side-cart__upgrade-button:hover {
    background: #082f49;
  }

  #{{ component_id }} .ht-side-cart__item-body,
  #{{ component_id }} .ht-side-cart__offer-body {
    min-width: 0;
  }

  #{{ component_id }} .ht-side-cart__item-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #{{ component_id }} .ht-side-cart__row-top {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  #{{ component_id }} .ht-side-cart__item-title,
  #{{ component_id }} .ht-side-cart__offer-title {
    margin: 0;
    font-size: 16px;
    line-height: 20px;
    font-weight: 700;
    letter-spacing: 0;
    color: var(--side-cart-ink);
  }

  #{{ component_id }} .ht-side-cart__item-title a,
  #{{ component_id }} .ht-side-cart__offer-title a {
    color: inherit;
    text-decoration: none;
  }

  #{{ component_id }} .ht-side-cart__item-subdesc,
  #{{ component_id }} .ht-side-cart__offer-subdesc,
  #{{ component_id }} .ht-side-cart__item-variant {
    margin-top: 5px;
    font-size: 15px;
    line-height: 20px;
    color: var(--side-cart-muted);
  }

  #{{ component_id }} .ht-side-cart__item-remove {
    border: 0;
    background: transparent;
    padding: 0;
    width: 20px;
    height: 20px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--side-cart-ink);
    cursor: pointer;
    flex-shrink: 0;
  }

  #{{ component_id }} .ht-side-cart__row-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-top: 16px;
  }

  #{{ component_id }} .ht-side-cart__item-controls {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    min-width: 0;
  }

  #{{ component_id }} .ht-side-cart__qty {
    display: inline-flex;
    align-items: center;
    width: 112px;
    height: 39px;
    border: 1px solid var(--side-cart-border);
    border-radius: var(--side-cart-pill-radius);
    background: transparent;
  }

  #{{ component_id }} .ht-side-cart__qty button {
    border: 0;
    background: transparent;
    width: 36px;
    height: 39px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--side-cart-ink);
    opacity: 0.7;
  }

  #{{ component_id }} .ht-side-cart__qty input {
    width: 40px;
    border: 0;
    background: transparent;
    text-align: center;
    font-size: 14px;
    line-height: 20px;
    font-weight: 400;
    color: var(--side-cart-ink);
    pointer-events: none;
  }

  #{{ component_id }} .ht-side-cart__price,
  #{{ component_id }} .ht-side-cart__subtotal-price {
    font-size: 14px;
    line-height: 20px;
    font-weight: 700;
    letter-spacing: 0;
    color: var(--side-cart-ink);
    white-space: nowrap;
  }

  #{{ component_id }} .ht-side-cart__footer {
    border-top: 1px solid rgba(11, 65, 102, 0.13);
    padding: 21px 20px 20px;
    background: var(--side-cart-surface);
  }

  #{{ component_id }} .ht-side-cart__subtotal {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  #{{ component_id }} .ht-side-cart__subtotal-label {
    font-size: 16px;
    line-height: 20px;
    font-weight: 700;
    color: var(--side-cart-ink);
  }

  #{{ component_id }} .ht-side-cart__subtotal-price {
    font-size: 16px;
  }

  #{{ component_id }} .ht-side-cart__payment-icons {
    border-top: 1px solid var(--side-cart-divider);
    border-bottom: 1px solid var(--side-cart-divider);
    padding: 9px 0;
    margin-top: 12px;
  }

  #{{ component_id }} .ht-side-cart__payment-icons-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 5px;
  }

  #{{ component_id }} .ht-side-cart__payment-icon {
    width: 33px;
    height: 23px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 4px;
    background: #fff;
  }

  #{{ component_id }} .ht-side-cart__payment-icon svg {
    width: 100%;
    height: 100%;
  }

  #{{ component_id }} .ht-side-cart__offers {
    background: #fff;
    padding: 20px;
  }

  #{{ component_id }} .ht-side-cart__offers-title {
    margin: 0 0 16px;
    font-size: 17px;
    line-height: 20px;
    font-weight: 600;
    letter-spacing: 0;
    color: var(--side-cart-ink);
  }

  #{{ component_id }} .ht-side-cart__offers-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  #{{ component_id }} .ht-side-cart__offer {
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr) auto;
    gap: 16px;
    align-items: start;
    min-height: 119px;
    padding: 20px 0 0;
  }

  #{{ component_id }} .ht-side-cart__offer:not(:last-child) {
    border-bottom: 1px solid rgba(11, 65, 102, 0.13);
    padding-bottom: 20px;
  }

  #{{ component_id }} .ht-side-cart__offer-media {
    width: 96px;
    height: 96px;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
  }

  #{{ component_id }} .ht-side-cart__offer-body {
    min-height: 96px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
  }

  #{{ component_id }} .ht-side-cart__offer-price {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    margin-top: 8px;
  }

  #{{ component_id }} .ht-side-cart__offer-price-compare {
    font-size: 16px;
    line-height: 20px;
    color: rgba(11, 65, 102, 0.7);
    text-decoration: line-through;
    margin-right: 6px;
  }

  #{{ component_id }} .ht-side-cart__offer-price-current {
    font-size: 16px;
    line-height: 20px;
    font-weight: 700;
    letter-spacing: 0;
    color: var(--side-cart-ink);
  }

  #{{ component_id }} .ht-side-cart__offer-select {
    position: relative;
    margin-top: 16px;
    width: 100%;
  }

  #{{ component_id }} .ht-side-cart__offer-select-handle {
    width: 100%;
    min-height: 44px;
    border: 1px solid var(--side-cart-ink);
    border-radius: 99999px;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 13px 33px 13px 21px;
    font-size: 14px;
    line-height: 16.5px;
    color: #1b1b1b;
  }

  #{{ component_id }} .ht-side-cart__offer-select-label {
    min-width: 0;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    font-weight: 400;
  }

  #{{ component_id }} .ht-side-cart__offer-select select {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
  }

  #{{ component_id }} .ht-side-cart__offer-action {
    min-height: 96px;
    display: flex;
    align-items: center;
  }

  #{{ component_id }} .ht-side-cart__button,
  #{{ component_id }} .ht-side-cart__offer-button {
    border: 0;
    border-radius: 99999px;
    background: var(--side-cart-ink);
    color: #fff;
    cursor: pointer;
    transition: background-color 0.2s ease, opacity 0.2s ease;
  }

  #{{ component_id }} .ht-side-cart__button:hover,
  #{{ component_id }} .ht-side-cart__offer-button:hover {
    background: #082f49;
  }

  #{{ component_id }} .ht-side-cart__offer-button {
    min-width: 0;
    padding: 10px 20px;
    font-size: 14px;
    line-height: 20px;
    font-weight: 600;
  }

  #{{ component_id }} .ht-side-cart__checkout {
    display: inline-flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    min-height: 55px;
    margin-top: 16px;
    text-decoration: none;
    font-size: 18px;
    line-height: 20px;
    font-weight: 700;
    background: #e6772a;
    border-radius: 99999px;
  }

  #{{ component_id }} .ht-side-cart__continue {
    display: block;
    width: 100%;
    margin-top: 14px;
    border: 0;
    background: transparent;
    color: rgba(11, 65, 102, 0.78);
    font-size: 15px;
    line-height: 1.2;
    font-weight: 600;
    cursor: pointer;
  }

  #{{ component_id }} .ht-side-cart__empty {
    padding: 40px 18px 16px;
    text-align: center;
    color: rgba(11, 65, 102, 0.68);
    font-size: 15px;
    line-height: 1.5;
  }

  @keyframes ht-side-cart-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 640px) {
    #{{ component_id }} .ht-side-cart__header,
    #{{ component_id }} .ht-side-cart__footer {
      padding-left: 18px;
      padding-right: 18px;
    }

    #{{ component_id }} .ht-side-cart__items,
    #{{ component_id }} .ht-side-cart__offers {
      padding-left: 18px;
      padding-right: 18px;
    }

    #{{ component_id }} .ht-side-cart__upgrade {
      margin-left: 18px;
      margin-right: 18px;
    }
  }
</style>

<div
  id="{{ component_id }}"
  x-data="sideCart_{{ section.id | replace: '-', '_' }}()"
  x-init="init()"
  data-side-cart-section-id="{{ section.id }}"
>
  <div
    class="ht-side-cart__layer"
    :class="{ 'is-open': open }"
    x-show="open"
    x-cloak
    @keydown.escape.window="close()"
  >
    <div class="ht-side-cart__backdrop" @click="close()"></div>

    <aside
      class="ht-side-cart__panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby="{{ component_id }}-title"
    >
      <div class="ht-side-cart__header" x-ref="header">
        <h2 class="ht-side-cart__title" id="{{ component_id }}-title">
          Cart ({{ cart.item_count }})
        </h2>
        <button type="button" class="ht-side-cart__close" @click="close()" aria-label="Close cart">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <div class="ht-side-cart__content">
        <div class="ht-side-cart__loading" x-show="loading" x-cloak>
          <div class="ht-side-cart__spinner" aria-hidden="true"></div>
        </div>

        {% capture side_cart_offers_markup %}
          {% if has_offer_items %}
            <div class="ht-side-cart__offers mt-4" x-ref="offers">
              <h3 class="ht-side-cart__offers-title">
                {{ section.settings.offers_heading }}
              </h3>

              <div class="ht-side-cart__offers-list">
                {% for i in (1..5) %}
                  {%- liquid
                    assign product_key = 'offer_product_' | append: i
                    assign offer_product = section.settings[product_key]
                  -%}
                  {% if offer_product != blank %}
                    {%- liquid
                      assign offer_variant = offer_product.selected_or_first_available_variant
                      assign offer_desc = offer_product.metafields.custom.ab_test_cart_desc
                      assign offer_subdesc = offer_product.metafields.custom.ab_test_cart_subdesc
                    -%}
                    <form
                      class="ht-side-cart__offer"
                      data-side-cart-offer
                      @submit.prevent="addOffer($event)"
                    >
                      <div class="ht-side-cart__offer-media">
                        <a href="{{ offer_product.url }}">
                          {% render 'image-helper', image: offer_product.featured_image, class: 'aspect-square w-full object-cover' %}
                        </a>
                      </div>

                      <div class="ht-side-cart__offer-body">
                        <div class="ht-side-cart__offer-title">
                          {% if section.settings.use_ab_test_cart_desc and offer_desc != blank %}
                            {% if offer_desc.type == 'rich_text_field' %}
                              {{ offer_desc | metafield_tag | strip_html }}
                            {% else %}
                              {{ offer_desc.value | default: offer_desc | strip_html }}
                            {% endif %}
                          {% else %}
                            <a href="{{ offer_product.url }}">{{ offer_product.title }}</a>
                          {% endif %}
                        </div>

                        {% if section.settings.show_ab_test_cart_subdesc and offer_subdesc != blank %}
                          <div class="ht-side-cart__offer-subdesc">
                            {% if offer_subdesc.type == 'rich_text_field' %}
                              {{ offer_subdesc | metafield_tag | strip_html }}
                            {% else %}
                              {{ offer_subdesc.value | default: offer_subdesc | strip_html }}
                            {% endif %}
                          </div>
                        {% endif %}

                        <div class="ht-side-cart__offer-price">
                          <span
                            class="ht-side-cart__offer-price-compare"
                            data-offer-compare-price
                            {% unless offer_variant.compare_at_price > offer_variant.price %}hidden{% endunless %}
                          >
                            {{ offer_variant.compare_at_price | money }}
                          </span>
                          <span class="ht-side-cart__offer-price-current" data-offer-price>
                            {{ offer_variant.price | money }}
                          </span>
                        </div>

                        {% unless offer_product.has_only_default_variant %}
                          <div class="ht-side-cart__offer-select">
                            <div class="ht-side-cart__offer-select-handle">
                              <span class="ht-side-cart__offer-select-label" data-offer-select-label>
                                {{ offer_variant.title }}
                              </span>
                              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                                <path d="M5.5 7.5L10 12L14.5 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                            </div>
                            <select name="id" @change="updateOfferVariant($event)">
                              {% for variant in offer_product.variants %}
                                <option
                                  value="{{ variant.id }}"
                                  data-price="{{ variant.price | money | escape }}"
                                  data-compare-price="{{ variant.compare_at_price | money | escape }}"
                                  data-has-compare="{% if variant.compare_at_price > variant.price %}true{% else %}false{% endif %}"
                                  {% if variant == offer_variant %}selected{% endif %}
                                  {% unless variant.available %}disabled{% endunless %}
                                >
                                  {{ variant.title }}
                                </option>
                              {% endfor %}
                            </select>
                          </div>
                        {% else %}
                          <input type="hidden" name="id" value="{{ offer_variant.id }}">
                        {% endunless %}
                      </div>

                      <div class="ht-side-cart__offer-action">
                        {% if offer_variant.available %}
                          <button type="submit" class="ht-side-cart__offer-button">
                            Add
                          </button>
                        {% else %}
                          <button type="button" class="ht-side-cart__offer-button" disabled>
                            Sold out
                          </button>
                        {% endif %}
                      </div>
                    </form>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          {% endif %}
        {% endcapture %}

        <div class="ht-side-cart__scroll">
          <div class="ht-side-cart__items" x-ref="items">
            {% if cart.item_count > 0 %}
              {% capture side_cart_upgrades_markup %}{% endcapture %}
              {% for item in cart.items %}
                {%- liquid
                  assign item_desc = item.product.metafields.custom.ab_test_cart_desc
                  assign item_subdesc = item.product.metafields.custom.ab_test_cart_subdesc
                  assign upsell_product = item.product.metafields.custom.ab_test_upsell.value
                  assign upsell_variant = blank
                  assign upsell_desc = blank
                  assign upgrade_delta = blank

                  if upsell_product != blank
                    assign upsell_variant = upsell_product.selected_or_first_available_variant
                    assign upsell_desc = upsell_product.metafields.custom.ab_test_cart_desc
                    assign upgrade_delta = upsell_variant.price | minus: item.final_price
                  endif
                -%}
                <div class="ht-side-cart__item-stack">
                  <div class="ht-side-cart__item">
                    <div class="ht-side-cart__item-media">
                      <a href="{{ item.url }}">
                        {% render 'image-helper', image: item.image, class: 'aspect-square w-full object-cover' %}
                      </a>
                    </div>

                    <div class="ht-side-cart__item-body">
                      <div class="ht-side-cart__row-top">
                        <div class="min-w-0">
                          <div class="ht-side-cart__item-title">
                            {% if section.settings.use_ab_test_cart_desc and item_desc != blank %}
                              {% if item_desc.type == 'rich_text_field' %}
                                {{ item_desc | metafield_tag | strip_html }}
                              {% else %}
                                {{ item_desc.value | default: item_desc | strip_html }}
                              {% endif %}
                            {% else %}
                              <a href="{{ item.url }}">{{ item.product.title }}</a>
                            {% endif %}
                          </div>

                          {% if section.settings.show_ab_test_cart_subdesc and item_subdesc != blank %}
                            <div class="ht-side-cart__item-subdesc">
                              {% if item_subdesc.type == 'rich_text_field' %}
                                {{ item_subdesc | metafield_tag | strip_html }}
                              {% else %}
                                {{ item_subdesc.value | default: item_subdesc | strip_html }}
                              {% endif %}
                            </div>
                          {% endif %}

                          {% unless item.product.has_only_default_variant %}
                            <div class="ht-side-cart__item-variant">
                              {% for option in item.options_with_values %}
                                {% unless option.name contains 'Default' %}
                                  {{ option.value }}{% unless forloop.last %} · {% endunless %}
                                {% endunless %}
                              {% endfor %}
                            </div>
                          {% endunless %}
                        </div>
                      </div>

                      <div class="ht-side-cart__row-bottom">
                        <div class="ht-side-cart__item-controls">
                          <div class="ht-side-cart__qty">
                            <button
                            type="button"
                            @click="change({{ forloop.index }}, {{ item.quantity | minus: 1 }})"
                            {% if item.quantity <= 1 %}disabled{% endif %}
                            aria-label="Decrease quantity"
                          >
                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="2" viewBox="0 0 10 2" fill="none" aria-hidden="true">
                              <path d="M9.25 0H0.75C0.335786 0 0 0.335786 0 0.75C0 1.16421 0.335786 1.5 0.75 1.5H9.25C9.66421 1.5 10 1.16421 10 0.75C10 0.335786 9.66421 0 9.25 0Z" fill="#0B4166"/>
                            </svg>
                          </button>
                          <input type="text" value="{{ item.quantity }}" readonly aria-label="Quantity">
                          <button
                            type="button"
                            @click="change({{ forloop.index }}, {{ item.quantity | plus: 1 }})"
                            aria-label="Increase quantity"
                          >
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                              <g opacity="0.7">
                                <path d="M10 5C9.58579 5 9.25 5.33579 9.25 5.75V9.25H5.75C5.33579 9.25 5 9.58579 5 10C5 10.4142 5.33579 10.75 5.75 10.75H9.25V14.25C9.25 14.6642 9.58579 15 10 15C10.4142 15 10.75 14.6642 10.75 14.25V10.75H14.25C14.6642 10.75 15 10.4142 15 10C15 9.58579 14.6642 9.25 14.25 9.25H10.75V5.75C10.75 5.33579 10.4142 5 10 5Z" fill="#0B4166"/>
                              </g>
                            </svg>
                          </button>
                          </div>

                          <button
                            type="button"
                            class="ht-side-cart__item-remove"
                            @click="remove({{ forloop.index }})"
                            aria-label="Remove {{ item.product.title }}"
                          >
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                              <g opacity="0.6">
                                <path fill-rule="evenodd" clip-rule="evenodd" d="M7.24994 5.25C7.24994 3.73122 8.48116 2.5 9.99994 2.5C11.5187 2.5 12.7499 3.73122 12.7499 5.25H15.75C16.1642 5.25 16.5 5.58579 16.5 6C16.5 6.41421 16.1642 6.75 15.75 6.75H14.9999L14.9998 12.2001C14.9998 13.8802 14.9997 14.7203 14.6728 15.362C14.3851 15.9265 13.9262 16.3854 13.3617 16.673C12.72 17 11.8799 17 10.1997 17H9.79999C8.11978 17 7.27968 17 6.63793 16.673C6.07343 16.3854 5.61448 15.9264 5.32687 15.3619C4.99989 14.7202 4.9999 13.8801 4.99994 12.1999L5.00005 6.75H4.25C3.83579 6.75 3.5 6.41421 3.5 6C3.5 5.58579 3.83579 5.25 4.25 5.25H7.24994ZM8.74994 5.25C8.74994 4.55964 9.30958 4 9.99994 4C10.6903 4 11.2499 4.55964 11.2499 5.25H8.74994ZM6.50007 6.75H13.4999L13.4998 12.2001C13.4998 13.0649 13.4986 13.6233 13.4639 14.0483C13.4305 14.4558 13.374 14.6068 13.3362 14.681C13.1924 14.9632 12.963 15.1927 12.6807 15.3365C12.6065 15.3743 12.4555 15.4308 12.048 15.4641C11.623 15.4988 11.0646 15.5 10.1997 15.5H9.79999C8.93513 15.5 8.37671 15.4988 7.95169 15.4641C7.54418 15.4308 7.3931 15.3743 7.31893 15.3365C7.03668 15.1927 6.80721 14.9632 6.6634 14.681C6.62561 14.6068 6.56909 14.4557 6.53581 14.0482C6.50109 13.6232 6.49994 13.0648 6.49995 12.1999L6.50007 6.75Z" fill="#0B4166"/>
                              </g>
                            </svg>
                          </button>
                        </div>

                        <div class="ht-side-cart__price">
                          {{ item.final_line_price | money }}
                        </div>
                      </div>
                    </div>
                  </div>

                </div>

                {% capture side_cart_upgrades_markup %}
                  {{ side_cart_upgrades_markup }}
                  {% if upsell_product != blank and upsell_variant != blank and upsell_variant.available and upgrade_delta > 0 %}
                    <div class="ht-side-cart__upgrade">
                      <h3 class="ht-side-cart__upgrade-title">
                        Upgrade To
                        {% if upsell_desc != blank %}
                          {% if upsell_desc.type == 'rich_text_field' %}
                            {{ upsell_desc | metafield_tag | strip_html }}
                          {% else %}
                            {{ upsell_desc.value | default: upsell_desc | strip_html }}
                          {% endif %}
                        {% else %}
                          {{ upsell_product.title }}
                        {% endif %}
                        For Just {{ upgrade_delta | money }}
                      </h3>

                      <div class="ht-side-cart__upgrade-row">
                        <div class="ht-side-cart__upgrade-media">
                          <a href="{{ upsell_product.url }}">
                            {% render 'image-helper', image: upsell_product.featured_image, class: 'aspect-square w-full object-cover' %}
                          </a>
                        </div>

                        <div class="ht-side-cart__upgrade-copy">
                          <div class="ht-side-cart__upgrade-name">
                            {% if upsell_desc != blank %}
                              {% if upsell_desc.type == 'rich_text_field' %}
                                {{ upsell_desc | metafield_tag | strip_html }}
                              {% else %}
                                {{ upsell_desc.value | default: upsell_desc | strip_html }}
                              {% endif %}
                            {% else %}
                              {{ upsell_product.title }}
                            {% endif %}
                          </div>
                          <div class="ht-side-cart__upgrade-price">
                            {{ upgrade_delta | money }}
                          </div>
                        </div>

                        <div class="ht-side-cart__upgrade-action">
                          <button
                            type="button"
                            class="ht-side-cart__upgrade-button"
                            @click="upgradeLine({{ forloop.index }}, {{ upsell_variant.id }}, {{ item.quantity }})"
                          >
                            Upgrade
                          </button>
                        </div>
                      </div>
                    </div>
                  {% endif %}
                {% endcapture %}
              {% endfor %}
            {% else %}
              <div class="ht-side-cart__empty">
                Your cart is empty.
              </div>
            {% endif %}
          </div>

          {% if show_additions_section %}
            <div class="ht-side-cart__additions">
              <div class="ht-side-cart__additions-inner">
                {{ side_cart_upgrades_markup }}
                {{ side_cart_offers_markup }}
              </div>
            </div>
          {% endif %}

        </div>

        <div class="ht-side-cart__footer" x-ref="totals">

          <div class="ht-side-cart__subtotal">
            <span class="ht-side-cart__subtotal-label">Subtotal</span>
            <span class="ht-side-cart__subtotal-price">{{ cart.total_price | money }}</span>
          </div>

          {% if section.settings.show_payment_icons and shop.enabled_payment_types.size > 0 %}
            <div class="ht-side-cart__payment-icons">
              <div class="ht-side-cart__payment-icons-row">
                {% for type in shop.enabled_payment_types %}
                  <span class="ht-side-cart__payment-icon">
                    {{ type | payment_type_svg_tag }}
                  </span>
                {% endfor %}
              </div>
            </div>
          {% endif %}

          {% if cart.item_count > 0 %}
            <a href="/checkout" class="ht-side-cart__button ht-side-cart__checkout">
              {{ section.settings.checkout_button_text }}
            </a>
          {% endif %}
{% comment %}{% endcomment %}
          {% comment %}<button type="button" class="ht-side-cart__continue" @click="close()">{% endcomment %}
            {% comment %}Continue shopping{% endcomment %}
          {% comment %}</button>{% endcomment %}
        </div>
      </div>
    </aside>
  </div>
</div>

<script>
  (() => {
    const dataName = 'sideCart_{{ section.id | replace: '-', '_' }}';
    const sectionId = {{ section.id | json }};
    const rootId = {{ component_id | json }};
    window.HighTideHasSideCart = true;
    window.HighTideSideCartRegistry = window.HighTideSideCartRegistry || {};

    function registerComponent() {
      if (!window.Alpine || window.HighTideSideCartRegistry[dataName]) {
        return;
      }

      window.HighTideSideCartRegistry[dataName] = true;

      window.Alpine.data(dataName, () => ({
        open: false,
        loading: false,
        cartButtonHandler: null,
        candyRackObserver: null,
        bodyMutationObserver: null,

        init() {
          document.body.classList.add('ht-side-cart-active');
          this.normalizeBodyState(false);
          this.suppressCandyRack();

          window.addEventListener('cart:add', async () => {
            this.loading = true;
            try {
              await this.refresh();
              this.setOpen(true);
            } catch (error) {
              console.error('[High Tide Side Cart] cart:add refresh failed', error);
            } finally {
              this.loading = false;
            }
          });

          this.cartButtonHandler = async (event) => {
            const button = event.target.closest('.cart-bubble-target');
            if (!button) return;

            event.preventDefault();
            event.stopPropagation();
            if (typeof event.stopImmediatePropagation === 'function') {
              event.stopImmediatePropagation();
            }

            this.setOpen(true);
            this.loading = true;

            try {
              await this.refresh();
            } catch (error) {
              console.error('[High Tide Side Cart] cart button refresh failed', error);
            } finally {
              this.loading = false;
            }
          };

          document.addEventListener('click', this.cartButtonHandler, true);
          this.updateBubble({{ cart.item_count | json }});
        },

        setOpen(isOpen) {
          this.open = isOpen;
          this.normalizeBodyState(isOpen);
          if (isOpen) {
            document.documentElement.style.setProperty('overflow', 'hidden');
            document.body.style.setProperty('overflow', 'hidden', 'important');
          } else {
            document.documentElement.style.removeProperty('overflow');
            document.body.style.removeProperty('overflow');
          }
        },

        close() {
          this.setOpen(false);
        },

        async fetchSectionMarkup() {
          const currentUrl = new URL(window.location.href);
          const sectionUrl = new URL(window.location.href);
          sectionUrl.searchParams.set('sections', sectionId);

          try {
            const response = await fetch(sectionUrl.toString(), {
              headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            const payload = await response.json();

            if (payload && payload[sectionId]) {
              return payload[sectionId];
            }
          } catch (error) {
            console.warn('[High Tide Side Cart] section rendering request failed, falling back to full page fetch', error);
          }

          const fallbackResponse = await fetch(currentUrl.toString(), {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
          });
          const fallbackHtml = await fallbackResponse.text();
          const fallbackDoc = new DOMParser().parseFromString(fallbackHtml, 'text/html');
          const fallbackRoot = fallbackDoc.querySelector(`#${rootId}`);

          if (!fallbackRoot) {
            throw new Error(`Side cart section root #${rootId} not found in fallback response`);
          }

          return fallbackRoot.outerHTML;
        },

        async refresh() {
          const markup = await this.fetchSectionMarkup();
          const html = new DOMParser().parseFromString(markup, 'text/html');
          const newHeader = html.querySelector(`#${rootId} [x-ref="header"]`);
          const newItems = html.querySelector(`#${rootId} [x-ref="items"]`);
          const newOffers = html.querySelector(`#${rootId} [x-ref="offers"]`);
          const newTotals = html.querySelector(`#${rootId} [x-ref="totals"]`);

          if (newHeader && this.$refs.header) {
            this.$refs.header.innerHTML = newHeader.innerHTML;
          }

          if (newItems && this.$refs.items) {
            this.$refs.items.innerHTML = newItems.innerHTML;
          }

          if (this.$refs.offers) {
            if (newOffers) {
              this.$refs.offers.innerHTML = newOffers.innerHTML;
            } else {
              this.$refs.offers.remove();
            }
          }

          if (newTotals && this.$refs.totals) {
            this.$refs.totals.innerHTML = newTotals.innerHTML;
          }

          const cart = await fetch('/cart.js').then((res) => res.json());
          this.updateBubble(cart.item_count);
        },

        async change(line, quantity) {
          if (quantity < 0) return;

          this.loading = true;
          try {
            const response = await fetch('/cart/change.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
              body: JSON.stringify({ line, quantity })
            });

            if (!response.ok) {
              throw new Error(`Cart change failed with status ${response.status}`);
            }

            await this.refresh();
          } finally {
            this.loading = false;
          }
        },

        async remove(line) {
          await this.change(line, 0);
        },

        async addOffer(event) {
          const form = event.target;
          const formData = new FormData(form);

          this.loading = true;
          try {
            const response = await fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'X-Requested-With': 'XMLHttpRequest' },
              body: formData
            });

            if (!response.ok) {
              throw new Error(`Cart add failed with status ${response.status}`);
            }

            window.dispatchEvent(new CustomEvent('cart:add'));
          } finally {
            this.loading = false;
          }
        },

        async upgradeLine(line, variantId, quantity) {
          this.loading = true;
          try {
            const removeResponse = await fetch('/cart/change.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
              body: JSON.stringify({ line, quantity: 0 })
            });

            if (!removeResponse.ok) {
              throw new Error(`Upgrade remove failed with status ${removeResponse.status}`);
            }

            const addResponse = await fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
              body: JSON.stringify({ id: variantId, quantity })
            });

            if (!addResponse.ok) {
              throw new Error(`Upgrade add failed with status ${addResponse.status}`);
            }

            await this.refresh();
            this.setOpen(true);
          } finally {
            this.loading = false;
          }
        },

        updateOfferVariant(event) {
          const select = event.target;
          const option = select.options[select.selectedIndex];
          const offer = select.closest('[data-side-cart-offer]');
          if (!offer || !option) return;

          const label = offer.querySelector('[data-offer-select-label]');
          const price = offer.querySelector('[data-offer-price]');
          const compare = offer.querySelector('[data-offer-compare-price]');

          if (label) {
            label.textContent = option.textContent.trim();
          }

          if (price) {
            price.textContent = option.dataset.price || '';
          }

          if (compare) {
            compare.textContent = option.dataset.comparePrice || '';
            compare.hidden = option.dataset.hasCompare !== 'true';
          }
        },

        updateBubble(count) {
          const button = document.querySelector('.cart-bubble-target');
          if (!button) return;

          let badge = button.querySelector('sup');
          if (!badge && count > 0) {
            badge = document.createElement('sup');
            badge.className = 'absolute -top-1 -right-4 border-2 border-inherit rounded-full w-4 h-4 flex items-center justify-center text-[10px] font-bold';
            button.appendChild(badge);
          }

          if (badge) {
            badge.textContent = count > 0 ? count : '';
            badge.classList.toggle('hidden', count === 0);
          }
        },

        normalizeBodyState(isOpen = this.open) {
          const bodyStyle = document.body.getAttribute('style') || '';
          const candyRackHidBody =
            document.body.id === 'candyrack-cart-body' ||
            /display:\s*none/i.test(bodyStyle) ||
            /visibility:\s*hidden/i.test(bodyStyle) ||
            /opacity:\s*0/i.test(bodyStyle) ||
            /pointer-events:\s*none/i.test(bodyStyle);

          if (candyRackHidBody) {
            document.body.removeAttribute('id');
          }

          if (isOpen || candyRackHidBody) {
            document.body.style.setProperty('display', 'block', 'important');
            document.body.style.setProperty('visibility', 'visible', 'important');
            document.body.style.setProperty('opacity', '1', 'important');
            document.body.style.setProperty('pointer-events', 'auto', 'important');
          }

          if (isOpen) {
            document.body.style.setProperty('overflow', 'hidden', 'important');
            return;
          }

          document.body.style.removeProperty('overflow');
          document.body.style.removeProperty('display');
          document.body.style.removeProperty('visibility');
          document.body.style.removeProperty('opacity');
          document.body.style.removeProperty('pointer-events');

          if (!document.body.getAttribute('style') || document.body.getAttribute('style').trim() === '') {
            document.body.removeAttribute('style');
          }
        },

        suppressCandyRack() {
          const hideInjectedNodes = () => {
            this.normalizeBodyState();

            document.querySelectorAll('#candyrack-slider-cart, [id^="candyrack"], [class*="candyrack-slider-cart"], [class*="candyrack-cart"]').forEach((node) => {
              if (node === document.body) return;
              node.style.setProperty('display', 'none', 'important');
              node.style.setProperty('visibility', 'hidden', 'important');
              node.style.setProperty('opacity', '0', 'important');
              node.style.setProperty('pointer-events', 'none', 'important');
            });
          };

          hideInjectedNodes();

          window.CandyRackSliderCart = window.CandyRackSliderCart || {};
          window.CandyRackSliderCart.open = () => {};
          window.CandyRackSliderCart.show = () => {};

          if (!this.candyRackObserver) {
            this.candyRackObserver = new MutationObserver(hideInjectedNodes);
            this.candyRackObserver.observe(document.body, {
              childList: true,
              subtree: true
            });
          }

          if (!this.bodyMutationObserver) {
            this.bodyMutationObserver = new MutationObserver(() => {
              this.normalizeBodyState();
            });

            this.bodyMutationObserver.observe(document.body, {
              attributes: true,
              attributeFilter: ['style', 'id', 'class']
            });
          }
        }
      }));
    }

    if (window.Alpine) {
      registerComponent();
    } else {
      document.addEventListener('alpine:init', registerComponent, { once: true });
    }
  })();
</script>

{% schema %}
{
  "name": "Side cart",
  "tag": "section",
  "class": "section-side-cart",
  "limit": 1,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "use_ab_test_cart_desc",
      "label": "Use custom.ab_test_cart_desc as title override",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_ab_test_cart_subdesc",
      "label": "Show custom.ab_test_cart_subdesc below title",
      "default": false
    },
    {
      "type": "text",
      "id": "offers_heading",
      "label": "Offers heading",
      "default": "Add items often bought together"
    },
    {
      "type": "checkbox",
      "id": "defer_offer_visibility",
      "label": "Keep recommended products below the fold",
      "default": true
    },
    {
      "type": "text",
      "id": "checkout_button_text",
      "label": "Checkout button text",
      "default": "Secure Checkout"
    },
    {
      "type": "product",
      "id": "offer_product_1",
      "label": "Offer product 1"
    },
    {
      "type": "product",
      "id": "offer_product_2",
      "label": "Offer product 2"
    },
    {
      "type": "product",
      "id": "offer_product_3",
      "label": "Offer product 3"
    },
    {
      "type": "product",
      "id": "offer_product_4",
      "label": "Offer product 4"
    },
    {
      "type": "product",
      "id": "offer_product_5",
      "label": "Offer product 5"
    }
  ],
  "presets": [
    {
      "name": "Side cart"
    }
  ]
}
{% endschema %}
