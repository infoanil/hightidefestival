{% if template.suffix == 'artist-ab-test' %}
<div id="choose-your-vibe-{{ section.id }}" class="choose-your-vibe-wrapper" style="display: none;">
<div class="vibe-container-inner container mx-auto py-10 lg:py-20">
{% else %}
<div class="container mx-auto py-20">
{% endif %}
    <div class="headings flex flex-col lg:flex-row lg:justify-between lg:items-end {% if template.suffix == 'artist-ab-test' %}mb-8 description-container{% else %}lg:mb-[50px]{% endif %} text-secondary-navy">
        {% if section.settings.heading != blank or section.settings.legend != blank %}
        <div class="">
            <p class="legend uppercase text-lg font-bold mb-4">{{ section.settings.legend }}</p>
            <h2 class="font-amaya text-[50px] leading-[46px] lg:text-[100px] lg:leading-[88px] uppercase letter-spacing-[-1px]">{{ section.settings.heading }}</h2>
        </div>
        {% endif %}
        <div class="tabs flex lg:max-w-[533px]  mt-5 mb-8 lg:my-0">
           <p class="font-semibold accordion-description">{{ section.settings.description }}</p>
        </div>
    </div>
    <div class="flex {% if template.suffix == 'artist-ab-test' %}flex-col h-auto{% else %}flex-col lg:flex-row h-[853px] lg:h-[600px]{% endif %} w-full gap-2"
        x-data="{ active: 0 }">
      
      {% for block in section.blocks %}
        {% assign index = forloop.index0 %}
        
        <div 
          {% if template.suffix != 'artist-ab-test' %}@mouseenter="active = {{ index }}"{% endif %}
          @click="active = {{ index }}"
          class="relative overflow-hidden cursor-pointer transition-all duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] shadow-2xl rounded-xl flex items-end"
          :class="active === {{ index }} ? 'flex-[3] md:flex-[5] lg:flex-[6] bg-[#363636] min-h-[400px]' : 'flex-1 h-auto bg-[#2a2a2a] min-h-[80px]'"
        >
          
          <img 
            src="{{ block.settings.image | img_url: 'master' }}" 
            alt="{{ block.settings.title }}"
            class="absolute inset-0 w-full h-full object-cover transition-all duration-700"
            :class="active === {{ index }} ? 'opacity-100 scale-100' : 'opacity-100 scale-110'"
          />

          <div x-show="active !== {{ index }}" x-transition.opacity class="gradient absolute inset-0 bg-black/50"></div>
          
          <div x-show="active !== {{ index }}" x-transition.opacity class="bg-black/50 w-full h-full flex {% if template.suffix == 'artist-ab-test' %}flex-row{% else %}lg:flex-col-reverse{% endif %} items-center justify-between [&_*]:z-1 lg:pt-[33px] lg:pb-[42px] px-5" style="{% if template.suffix == 'artist-ab-test' %}height: 117px;{% endif %}">
            <h3 class="font-extrabold text-white uppercase text-[25px] md:text-[30px] leading-[24px] tracking-[-1px] {% if template.suffix != 'artist-ab-test' %}lg:[writing-mode:vertical-rl] lg:rotate-180{% endif %} z-1 pointer-events-none max-sm:w-[164px] {% if template.suffix == 'artist-ab-test' %} hidden{% endif %}">
              {{ block.settings.title }}
            </h3>
            <img
            src="{{ block.settings.icon | img_url: 'master' }}"
            class="w-[50px] md:w-[58px] {% if template.suffix == 'artist-ab-test' %} hidden{% endif %}"
            >
          </div>

          <div 
            x-show="active === {{ index }}"
            x-transition:enter="transition ease-out duration-500 delay-300"
            x-transition:enter-start="opacity-0 translate-y-8"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="flex flex-col justify-between relative px-3 py-5 md:p-7 w-full h-full z-1 bg-gradient-to-b from-transparent to-black/40"
            style="{% if template.suffix == 'artist-ab-test' %}height: stretch;{% endif %}"
          >
            <img
            src="{{ block.settings.icon | img_url: 'master' }}"
            class="w-[50px] md:w-[58px]"
            >
              <div>
                <h3 class="text-[25px] leading-[24px] tracking-[-2px] md:text-[40px] lg:text-[50px] lg:leading-[1em] md:tracking-[-4px] font-black mb-3 uppercase  text-white ">{{  block.settings.title }}</h3>
                <p class="text-[15px] leading-[18px] md:text-xl md:leading-[22px] uppercase  text-white font-bold lg:font-extrabold tracking-[-1px]">
                  {{ block.settings.description }}
                </p>
              </div>
            
            

          </div>

        </div>
      {% endfor %}

    </div>
  </div>
{% if template.suffix == 'artist-ab-test' %}
</div>
</div>

<script>
  (function() {
    function moveVibeSection() {
      const wrapper = document.getElementById('choose-your-vibe-{{ section.id }}');
      const target = document.querySelector('[data-what-to-expect]');
      
      if (wrapper && target) {
        target.appendChild(wrapper);
        wrapper.style.display = 'block';

        const inner = wrapper.querySelector('.vibe-container-inner');
        if (inner) {
          inner.classList.remove('container', 'mx-auto', 'py-10', 'lg:py-20');
          inner.classList.add('pb-4');
        }
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', moveVibeSection);
    } else {
      moveVibeSection();
    }
  })();
</script>
{% else %}
</div>
{% endif %}


  {% schema %}
  {
    "name": "Choose Your Vibe",
    "tag": "section",
    "class": "section-choose-your-vibe",
    "settings": [
      {
        "type": "text",
        "id": "legend",
        "label": "Legend Text",
        "default": "explore the grounds"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "choose your vibe"
      },
      {
        "type": "textarea",
        "id": "description",
        "label": "Description",
        "default": "Plan your flow through the waterpark. From the massive energy of the Main Stage to the intimate vibes of Sunset, there's a sound for every moment."
      }
    ],
    "blocks": [
      {
        "type": "stage",
        "name": "Stage",
        "settings": [
                    {
            "type": "image_picker",
            "id": "icon",
            "label": "Icon"
          },
          {
            "type": "text",
            "id": "title",
            "label": "Stage Title",
            "default": "Main Stage"
          },
          {
            "type": "image_picker",
            "id": "image",
            "label": "Stage Image"
          },
          
          {
            "type": "textarea",
            "id": "description",
            "label": "Stage Description",
            "default": "The heartbeat of High Tide. Massive sound, pyrotechnics, and the biggest acts."
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Choose Your Vibe",
        "blocks": [
          {
            "type": "stage"
          },
          {
            "type": "stage"
          },
          {
            "type": "stage"
          }
        ]
      }
    ]
  }
  {% endschema %}
{% if template.suffix == 'artist-ab-test' %}
<style>
    .artist-ab-test .accordion-description{
        font-weight: 600;
        font-size: 16px;
        line-height: 24px;
        letter-spacing: normal;
    }
    @media (max-width: 767px) {
        .artist-ab-test .description-container{
            margin-bottom: 0 !important;
        }
    }
</style>
{% endif %}
