<div class="newsletter z-0 md:h-[580px] h-[800px] lg:h-[800px] relative flex items-end pt-[64px] pb-8 md:pt-[70px] md:pb-[60px] lg:pt-[100px] lg:pb-[73px] overflow-hidden">
    {% comment %} Media {% endcomment %}
    <div class="media absolute inset-0 z-[-1] bg-gray-400">    
        {% render 'image-helper'
            , image: section.settings.image
            , max_width: 2000
            , sizes: '(min-width: 1024px) 50vw, 100vw'
            , class: 'w-full h-full object-cover object-bottom hidden md:block'
        %}
        {% render 'image-helper'
            , image: section.settings.image_mobile
            , max_width: 2000
            , sizes: '(min-width: 1024px) 50vw, 100vw'
            , class: 'w-full h-full object-cover object-bottom block md:hidden'
        %}
    </div>
    {% comment %} Content {% endcomment %}
    <div class="mx-auto container h-full text-white flex flex-col">    
        <div class="headings flex-0 max-w-[757px]">
            <h2 class="font-amaya text-[60px] leading-[51px] tracking-[-4px] md:text-[80px] md:leading-[72px] lg:text-[120px] lg:leading-[105px] uppercase lg:tracking-[-5px]">{{  section.settings.heading | default: "Subscribe to our newsletter" }}</h2>
            <a href="{{ section.settings.button_url }}" class="bg-primary-lightblue hover:bg-secondary-navy text-secondary-navy hover:text-white transition duration-200 uppercase font-extrabold px-7.5 py-4.5 rounded-[5px] mt-7.5  inline-flex">{{ section.settings.button_title }}</a>
        </div>
        <div class="tags flex-1 flex items-end max-w-[299px]">
            <ul class="flex gap-[5px] flex-wrap" role="list">
                {% if section.blocks.size > 0 %}
                    {% for block in section.blocks %}
                        <li role="listitem"class="bg-white text-secondary-navy font-bold rounded-full uppercase px-[10px] py-[5px]">
                            {{ block.settings.text }}
                        </li>
                    {% endfor %}
                {%  else %}
                    {% for i in (1..3) %}
                        <li class="bg-white text-secondary-navy font-bold rounded-full uppercase px-[10px] py-[5px] mb-2 tracking-[-1px]">
                            Example Tag {{ i }}
                        </li>
                    {% endfor %}
                {% endif %}
            </ul>
        </div>
    </div>
</div>


{% schema %}
  {
  "name": "Call to Action",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
        {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image Mobile"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading"
    },
     {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_title",
      "label": "Button title",
      "default": "Button title"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button url"
    }
  ],
  "blocks": [
    {
      "name": "Item",
      "type": "item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Item"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Call to Action"
    }
  ]
}  
{% endschema %}