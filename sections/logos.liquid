{% assign bg_color = section.settings.background_color %}

<style>
  #section-logos-{{ section.id }} {
    background-color: {{ bg_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    margin-top: {{ section.settings.margin_top_mobile }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
  }

  #section-logos-{{ section.id }} .logos-title {
    color: {{ section.settings.title_color }};
  }

  @media (min-width: 768px) {
    #section-logos-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
      margin-top: {{ section.settings.margin_top_desktop }}px;
      margin-bottom: {{ section.settings.margin_bottom_desktop }}px;
    }
  }

  #section-logos-{{ section.id }} .logos-marquee {
    overflow: hidden;
    user-select: none;
    display: flex;
    gap: 2rem;
    --gap: 2rem;
  }

  @media (min-width: 768px) {
    #section-logos-{{ section.id }} .logos-marquee {
      gap: 3rem;
      --gap: 3rem;
    }
  }

  #section-logos-{{ section.id }} .logos-track {
    list-style: none;
    flex-shrink: 0;
    min-width: 100%;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 2rem;
    {% if section.settings.autoplay == "true" %}
    animation: logos-scroll-{{ section.id }} {{ section.settings.animation_duration }}s linear infinite;
    {% else %}
    animation: none;
    {% endif %}
  }

  @media (min-width: 768px) {
    #section-logos-{{ section.id }} .logos-track {
      gap: 3rem;
    }
  }

  #section-logos-{{ section.id }} .logos-marquee:hover .logos-track {
    animation-play-state: paused;
  }

  @keyframes logos-scroll-{{ section.id }} {
    to {
      transform: translateX(calc(-100% - var(--gap)));
    }
  }
</style>

<section
  id="section-logos-{{ section.id }}"
  aria-labelledby="logos-heading-{{ section.id }}"
>
  <div id="section-logos" class="mx-auto">
    {% if section.settings.title != blank %}
      <h2
        id="logos-heading-{{ section.id }}"
        class="logos-title text-center font-amaya text-[50px] leading-[46px] md:text-[60px] md:leading-[56px] lg:text-[100px] lg:leading-[88px] uppercase tracking-[-1px] mb-8 sm:mb-12"
      >
        {{ section.settings.title | escape }}
      </h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="logos-marquee">
        <ul class="logos-track">
          {% for i in (1..3) %}
            {% for block in section.blocks %}
              <li
                class="flex-shrink-0"
                {% if i == 1 %}
                  {{- block.shopify_attributes -}}
                {% endif %}
              >
                {% if block.settings.logo != blank %}
                  {% if block.settings.link != blank %}
                    <a href="{{ block.settings.link }}" target="_blank" rel="noopener">
                      <div class="w-full max-w-28 flex justify-center items-center max-w-28 max-h-28">
                        {{
                          block.settings.logo
                          | image_url: width: 300
                          | image_tag:
                            loading: 'lazy',
                            alt: block.settings.logo.alt,
                            class: 'w-full h-auto object-contain max-w-28 max-h-28'
                        }}
                      </div>
                    </a>
                  {% else %}
                    <div class="w-full max-w-28 flex justify-center items-center max-w-28 max-h-28">
                      {{
                        block.settings.logo
                        | image_url: width: 300
                        | image_tag:
                          loading: 'lazy',
                          alt: block.settings.logo.alt,
                          class: 'w-full h-auto object-contain max-w-28 max-h-28'
                      }}
                    </div>
                  {% endif %}
                {% else %}
                  <div class="w-full max-w-28 aspect-video flex justify-center items-center bg-[var(--surface-secondary)] border border-dashed border-[var(--interactive-border)] rounded-lg">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="1.5"
                      stroke="currentColor"
                      class="w-12 h-12 text-[var(--text-secondary)]"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                    </svg>
                  </div>
                {% endif %}
              </li>
            {% endfor %}
          {% endfor %}
        </ul>

        <ul class="logos-track" aria-hidden="true">
          {% for i in (1..3) %}
            {% for block in section.blocks %}
              <li class="flex-shrink-0">
                {% if block.settings.logo != blank %}
                  {% if block.settings.link != blank %}
                    <a href="{{ block.settings.link }}" target="_blank" rel="noopener">
                      <div class="w-full max-w-28 flex justify-center items-center max-w-28 max-h-28">
                        {{
                          block.settings.logo
                          | image_url: width: 300
                          | image_tag:
                            loading: 'lazy',
                            alt: block.settings.logo.alt,
                            class: 'w-full h-auto object-contain max-w-28 max-h-28'
                        }}
                      </div>
                    </a>
                  {% else %}
                    <div class="w-full max-w-28 flex justify-center items-center max-w-28 max-h-28">
                      {{
                        block.settings.logo
                        | image_url: width: 300
                        | image_tag:
                          loading: 'lazy',
                          alt: block.settings.logo.alt,
                          class: 'w-full h-auto object-contain max-w-28 max-h-28'
                      }}
                    </div>
                  {% endif %}
                {% else %}
                  <div class="w-full max-w-28 aspect-video flex justify-center items-center bg-[var(--surface-secondary)] border border-dashed border-[var(--interactive-border)] rounded-lg">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="1.5"
                      stroke="currentColor"
                      class="w-12 h-12 text-[var(--text-secondary)]"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                    </svg>
                  </div>
                {% endif %}
              </li>
            {% endfor %}
          {% endfor %}
        </ul>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Logos",
  "tag": "section",
  "class": "section-logos",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Partners"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#0B4166"
    },
    {
      "type": "range",
      "id": "animation_duration",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "s",
      "label": "Animation Speed (seconds)",
      "default": 140,
      "info": "Higher values = slower animation"
    },
    {
      "type": "select",
      "id": "autoplay",
      "label": "Autoplay",
      "options": [
        {
          "value": "true",
          "label": "Enabled"
        },
        {
          "value": "false",
          "label": "Disabled"
        }
      ],
      "default": "true",
      "info": "Enable or disable automatic scrolling of logos"
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Margin Top (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Margin Bottom (Mobile)",
      "default": 0
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "margin_top_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Margin Top (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Margin Bottom (Desktop)",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Logo Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logos",
      "blocks": [
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        }
      ]
    }
  ]
}
{% endschema %}
