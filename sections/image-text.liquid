{% assign image = section.settings.image %}
{% assign heading = section.settings.heading %}
{% assign text = section.settings.text %}
{% assign button_label = section.settings.button_label %}
{% assign button_link = section.settings.button_link %}
{% assign layout = section.settings.layout %}
{% assign ratio = section.settings.image_ratio %}

<section aria-labelledby="section-{{ section.id }}-title" class="py-[var(--space-xl)] px-[var(--space-md)] bg-bg-color">

  <div class="mx-auto max-w-7xl">

    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 sm:gap-10">

      <!-- IMAGE SIDE -->
      <div class="{% if layout == 'image_right' %} sm:order-2 {% else %} sm:order-1 {% endif %}">

        {% if image %}
          <div class="{{ ratio }} w-full overflow-hidden rounded-lg shadow-lg bg-[var(--surface-secondary)]">
            {% render 'image-helper'
              , image: image
              , class: 'w-full h-full object-cover'
            %}
          </div>

        {% else %}
          <div class="{{ ratio }} w-full flex items-center justify-center
                      rounded-lg border-2 border-dashed border-[var(--interactive-border)]
                      bg-[var(--surface-secondary)] text-[var(--text-secondary)]">
            Image Placeholder (Select Image)
          </div>
        {% endif %}

      </div>

      <!-- TEXT SIDE -->
      <div class="flex flex-col justify-center
                  {% if layout == 'image_right' %} sm:order-1 {% else %} sm:order-2 {% endif %}">

        <h2 id="section-{{ section.id }}-title"  class="font-amaya text-[50px] leading-[46px] md:text-[60px] md:leading-[60px] lg:text-[80px] lg:leading-[74px] uppercase tracking-[-1px] mb-6 text-secondary-navy">
          {{ heading | escape }}
        </h2>

        <div class="mt-[var(--space-md)] text-[17px] tracking-[-1px] text-primary-black space-y-[var(--space-sm)] [&_ul]:list-disc [&_ul]:pl-5  ">
          {{ text }}
        </div>

        {% if button_label and button_link %}
          <div class="mt-[var(--space-lg)]">
            <a
              href="{{ button_link }}"
              aria-label="{{ button_label }}"
              class="inline-flex items-center justify-center
                      rounded-md border border-[var(--interactive-border)]
                      bg-[var(--interactive-default)]
                      px-[var(--space-lg)] py-[var(--space-sm)]
                      text-[var(--text-on-interactive)]
                      font-medium transition
                      hover:bg-[var(--interactive-hover)]">
              {{ button_label }}
            </a>
          </div>
        {% endif %}

      </div>

    </div>

  </div>
</section>


{% schema %}
  {
    "name": "Image with Text",
    "tag": "section",
    "settings": [
      {
        "type": "header",
        "content": "Layout & Design"
      },
      {
        "type": "range",
        "id": "padding_y",
        "min": 2,
        "max": 20,
        "step": 2,
        "label": "Vertical Padding (py-)",
        "default": 16,
        "info": "Tailwind spacing units applied as py-X"
      },
      {
        "type": "select",
        "id": "layout",
        "label": "Layout",
        "options": [
          {
            "value": "image_left",
            "label": "Image on Left"
          }, {
            "value": "image_right",
            "label": "Image on Right"
          }
        ],
        "default": "image_left"
      },
      {
        "type": "select",
        "id": "image_ratio",
        "label": "Image Aspect Ratio",
        "options": [
          {
            "value": "aspect-h-3 aspect-w-4",
            "label": "Portrait (4:3)"
          }, {
            "value": "aspect-h-9 aspect-w-16",
            "label": "Landscape (16:9)"
          }, {
            "value": "aspect-h-1 aspect-w-1",
            "label": "Square (1:1)"
          }
        ],
        "default": "aspect-h-3 aspect-w-4"
      }, {
        "type": "header",
        "content": "Content"
      }, {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      }, {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Bring your brand story to life"
      }, {
        "type": "richtext",
        "id": "text",
        "label": "Text content",
        "default": "<p>Use this section to highlight a unique feature, product line, or key brand value. Text can be formatted using the rich text editor.</p>"
      }, {
        "type": "text",
        "id": "button_label",
        "label": "Button label",
        "default": "Shop Now"
      }, {
        "type": "url",
        "id": "button_link",
        "label": "Button link"
      }
    ],
    "presets": [
      {
        "name": "Image with Text",
        "category": "Layout"
      }
    ]
  }
{% endschema %}